@model Pharma_Script.Models.Receptionist

<div class="row g-4 align-items-center">
    <div class="col-12 col-md-4 text-center border-end">
        <div class="mb-3">
            <div class="rounded-circle bg-light text-primary d-inline-flex align-items-center justify-content-center border" style="width: 100px; height: 100px; font-size: 2.5rem; font-weight: bold;">
                @Model.FirstName[0]
            </div>
        </div>
        <h5 class="mb-1 text-dark fw-bold">@Model.FirstName @Model.LastName</h5>
        <span class="badge bg-light text-secondary border rounded-pill px-3 py-1.5 font-semibold">Receptionist</span>
    </div>

    <div class="col-12 col-md-8">
        <div class="row g-3">
            <div class="col-6">
                <span class="text-muted d-block small">Email Address</span>
                <strong class="text-dark small"><i class="bi bi-envelope me-1.5 text-primary"></i>@Model.Email</strong>
            </div>
            <div class="col-6">
                <span class="text-muted d-block small">Phone Number</span>
                <strong class="text-dark small"><i class="bi bi-telephone me-1.5 text-primary"></i>@Model.Phone</strong>
            </div>
            <div class="col-6 mt-3">
                <span class="text-muted d-block small">Organization Scope</span>
                <strong class="text-dark small">@(Model.OrganizationName ?? "N/A")</strong>
            </div>
            <div class="col-6 mt-3">
                <span class="text-muted d-block small">Assigned Branch</span>
                <strong class="text-dark small">@(Model.BranchName ?? "All Branches")</strong>
            </div>
            <div class="col-6 mt-3">
                <span class="text-muted d-block small">Status</span>
                <span class="badge bg-@(Model.IsActive ? "success-subtle text-success" : "danger-subtle text-danger") border rounded px-2.5 py-1">
                    @(Model.IsActive ? "Active Access" : "Deactivated")
                </span>
            </div>
            <div class="col-6 mt-3">
                <span class="text-muted d-block small">Created At</span>
                <strong class="text-secondary small">@Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</strong>
            </div>
        </div>
    </div>
</div>

<div class="modal-footer px-0 pb-0 mt-4 border-0">
    <button type="button" class="btn btn-secondary px-3.5" data-bs-dismiss="modal">Close</button>
</div>
