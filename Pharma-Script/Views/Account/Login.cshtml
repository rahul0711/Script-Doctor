@model Pharma_Script.ViewModels.Account.LoginViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Login";
}

<div class="login-bg">
    <div class="login-card">
        <div class="text-center mb-4">
            <a href="/" class="d-inline-block mb-2 text-decoration-none" style="max-width: 100%;">
                <img src="~/assets/Cloud Doctor Logo.png" alt="Cloud Doctor" style="max-height: 115px; max-width: 260px; width: 100%; height: auto; object-fit: contain;" />
            </a>
            <p class="text-muted small">Sign in to your healthcare console</p>
        </div>

        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" autocomplete="off">
            @Html.AntiForgeryToken()

            <div class="text-danger small mb-3 text-center" asp-validation-summary="ModelOnly"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label small fw-semibold text-secondary"></label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted" style="padding-right: 5px;"><i class="bi bi-envelope fs-6"></i></span>
                    <input asp-for="Email" type="email" class="form-control border-start-0 ps-2" placeholder="name@company.com" required />
                </div>
                <span asp-validation-for="Email" class="text-danger small mt-1 d-block" style="font-size: 0.75rem;"></span>
            </div>

            <div class="mb-3">
                <div class="d-flex justify-content-between">
                    <label asp-for="Password" class="form-label small fw-semibold text-secondary"></label>
                </div>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted" style="padding-right: 5px;"><i class="bi bi-lock fs-6"></i></span>
                    <input asp-for="Password" type="password" class="form-control border-start-0 ps-2" placeholder="••••••••" required />
                </div>
                <span asp-validation-for="Password" class="text-danger small mt-1 d-block" style="font-size: 0.75rem;"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label text-muted small fw-medium"></label>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                Sign In
            </button>
        </form>

        @{
            var returnUrl = ViewData["ReturnUrl"] as string;
            var publicSlug = !string.IsNullOrEmpty(returnUrl) && returnUrl.StartsWith("/")
                ? returnUrl.Trim('/').Split('/')[0]
                : null;
        }
        @if (!string.IsNullOrEmpty(publicSlug) && returnUrl!.Contains("/doctors/"))
        {
            <div class="text-center mt-3 small text-muted">
                New patient?
                <a href="/@publicSlug/register?returnUrl=@Uri.EscapeDataString(returnUrl)">Create an account</a>
            </div>
        }
    </div>
</div>
