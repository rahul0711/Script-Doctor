@model Pharma_Script.ViewModels.CMS.ServiceViewModel

<form asp-action="Edit" asp-controller="Services" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ServiceID" />
    <div class="row g-3">
        <div class="col-12">
            <label asp-for="ServiceName" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="ServiceName" class="form-control" />
            <span asp-validation-for="ServiceName" class="text-danger small"></span>
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label small fw-semibold text-secondary"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-12">
            @if (!string.IsNullOrEmpty(Model.ExistingServiceImage))
            {
                <div class="mb-2"><img src="@Model.ExistingServiceImage" style="height:56px;border-radius:6px;" /></div>
            }
            <label asp-for="ServiceImage" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="ServiceImage" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
            <span class="form-text small">Leave empty to keep the current image.</span>
        </div>
        <div class="col-12">
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label small fw-semibold text-secondary">Active</label>
            </div>
        </div>
    </div>
    <div class="modal-footer px-0 pb-0 mt-4 border-0">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Update Service</button>
    </div>
</form>
