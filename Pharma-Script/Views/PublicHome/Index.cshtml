@model Pharma_Script.ViewModels.Public.PublicHomeViewModel
@{
    Layout = "~/Views/Public/Shared/_PublicLayout.cshtml";
    var tenant = Model.Tenant;
    var org = tenant.Organization;
    var cms = tenant.CMSSettings;
    var slug = org.OrganizationSlug;
    string PubUrl(string path) => $"/{slug}/{path}".TrimEnd('/');
    var primaryHero = Model.HeroSections.FirstOrDefault();
}



<!-- Featured Doctors Section -->
<section class="pub-section pub-section-soft" id="doctors">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <span class="pub-eyebrow">Our Specialists</span>
                <h2 class="pub-heading mb-0">Featured Doctors</h2>
            </div>
            <a href="@PubUrl("doctors")" class="pub-btn-outline d-none d-md-flex">View All Doctors <i class="bi bi-arrow-right ms-2"></i></a>
        </div>

        @if (Model.FeaturedDoctors.Any())
        {
            <div class="row g-4">
                @foreach (var doc in Model.FeaturedDoctors)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="pub-doctor-card d-flex flex-column">
                            @if (!string.IsNullOrEmpty(doc.ProfileImage))
                            {
                                <img src="@doc.ProfileImage" alt="Dr. @doc.FirstName @doc.LastName" class="pub-doctor-photo" loading="lazy" />
                            }
                            else
                            {
                                <div class="pub-doctor-photo d-flex align-items-center justify-content-center">
                                    <i class="bi bi-person-fill text-secondary" style="font-size:5rem; opacity:0.2;"></i>
                                </div>
                            }
                            
                            <div class="pub-doctor-body d-flex flex-column flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <h3 class="pub-doctor-name">Dr. @doc.FirstName @doc.LastName</h3>
                                        <div class="pub-doctor-meta">
                                            @(doc.Qualification ?? doc.DepartmentName) &middot; @doc.ExperienceYears yrs exp.
                                        </div>
                                    </div>
                                    <div class="pub-badge pub-badge-available">
                                        <i class="bi bi-circle-fill" style="font-size:0.5rem;"></i> Today
                                    </div>
                                </div>
                                
                                @if (doc.SpecializationNames.Any())
                                {
                                    <div class="mb-3">
                                        @foreach (var spec in doc.SpecializationNames.Take(2))
                                        {
                                            <span class="badge rounded-pill bg-light text-dark border me-1 fw-normal">@spec</span>
                                        }
                                    </div>
                                }

                                <div class="pub-doctor-fees mt-auto">
                                    @if (doc.VideoConsultationFee > 0)
                                    {
                                        <div class="pub-fee-item">
                                            <span class="pub-fee-label"><i class="bi bi-camera-video me-1"></i>Video</span>
                                            <span class="pub-fee-value">₹@doc.VideoConsultationFee</span>
                                        </div>
                                    }
                                    @if (doc.VoiceConsultationFee > 0)
                                    {
                                        <div class="pub-fee-item">
                                            <span class="pub-fee-label"><i class="bi bi-telephone me-1"></i>Voice</span>
                                            <span class="pub-fee-value">₹@doc.VoiceConsultationFee</span>
                                        </div>
                                    }
                                    @if (doc.ConsultationFee > 0)
                                    {
                                        <div class="pub-fee-item">
                                            <span class="pub-fee-label"><i class="bi bi-building me-1"></i>Clinic</span>
                                            <span class="pub-fee-value">₹@doc.ConsultationFee</span>
                                        </div>
                                    }
                                </div>

                                <div class="d-flex gap-2">
                                    <a href="@PubUrl($"doctors/{doc.DoctorID}")" class="pub-btn-outline flex-fill" style="padding: 0.6rem 1rem;">View Profile</a>
                                    <a href="@PubUrl($"doctors/{doc.DoctorID}/book")" class="pub-btn-cta flex-fill" style="padding: 0.6rem 1rem;">Book</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="text-center mt-5 d-md-none">
                <a href="@PubUrl("doctors")" class="pub-btn-outline w-100">View All Doctors</a>
            </div>
        }
        else
        {
            <div class="text-center text-muted p-5 bg-white rounded shadow-sm">
                <i class="bi bi-calendar-x fs-1 text-secondary mb-3"></i>
                <p>Our doctor listings will be available here shortly.</p>
            </div>
        }
    </div>
</section>


<!-- Search & Specializations Filter -->
<section class="pub-section" style=" padding-bottom:3rem;">
    <div class="container">
        <div class="pub-search-container">
            <h2 class="pub-heading text-center mb-4">Find & Book Top Doctors</h2>
            <div class="position-relative">
                <i class="bi bi-search pub-search-icon"></i>
                <input type="text" class="pub-search-input" id="doctorSearch" placeholder="Search Doctor, Specialty or Symptoms..." />
            </div>
            
            <div class="pub-chips-container justify-content-center">
                <a href="@PubUrl("doctors")" class="pub-chip active">All</a>
                @foreach (var dept in Model.Departments.Take(8))
                {
                    <a href="@PubUrl($"doctors?departmentId={dept.DepartmentID}")" class="pub-chip">@dept.DepartmentName</a>
                }
            </div>
        </div>
    </div>
</section>




<!-- Services Section -->
@if (Model.Services.Any())
{
    <section class="pub-section" id="services">
        <div class="container">
            <div class="text-center mb-5">
                <span class="pub-eyebrow">Excellence in Healthcare</span>
                <h2 class="pub-heading">Our Services</h2>
            </div>
            
            <div class="row g-4">
                @foreach (var svc in Model.Services)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="pub-service-card">
                            <div class="pub-service-icon">
                                <!-- Fallback icon logic if needed, or static for premium feel -->
                                @if(svc.ServiceName.Contains("Video", StringComparison.OrdinalIgnoreCase)) { <i class="bi bi-camera-video"></i> }
                                else if(svc.ServiceName.Contains("Voice", StringComparison.OrdinalIgnoreCase)) { <i class="bi bi-telephone"></i> }
                                else if(svc.ServiceName.Contains("Clinic", StringComparison.OrdinalIgnoreCase)) { <i class="bi bi-hospital"></i> }
                                else if(svc.ServiceName.Contains("Prescription", StringComparison.OrdinalIgnoreCase)) { <i class="bi bi-file-medical"></i> }
                                else if(svc.ServiceName.Contains("Report", StringComparison.OrdinalIgnoreCase)) { <i class="bi bi-clipboard2-pulse"></i> }
                                else { <i class="bi bi-heart-pulse"></i> }
                            </div>
                            <h4 class="fw-bold mb-3">@svc.ServiceName</h4>
                            <p class="text-muted mb-0">@svc.Description</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- About Section -->
@if (!string.IsNullOrWhiteSpace(cms?.AboutUs) || !string.IsNullOrWhiteSpace(cms?.Mission) || !string.IsNullOrWhiteSpace(cms?.Vision))
{
    <section class="pub-section pub-section-soft" id="about">
        <div class="container">
            <div class="row g-5 align-items-center">
                <div class="col-lg-6">
                    <span class="pub-eyebrow">About Hospital</span>
                    <h2 class="pub-heading mb-4">Caring for you and your family</h2>
                    @if (!string.IsNullOrWhiteSpace(cms?.AboutUs))
                    {
                        <p class="pub-subheading mb-0 text-muted">@cms.AboutUs</p>
                    }
                </div>
                <div class="col-lg-6">
                    <div class="row g-4">
                        @if (!string.IsNullOrWhiteSpace(cms?.Mission))
                        {
                            <div class="col-12">
                                <div class="bg-white p-4 rounded-4 shadow-sm border">
                                    <div class="d-flex align-items-start gap-3">
                                        <div class="text-primary fs-2 lh-1"><i class="bi bi-bullseye"></i></div>
                                        <div>
                                            <h5 class="fw-bold mb-2">Our Mission</h5>
                                            <p class="text-muted mb-0">@cms.Mission</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(cms?.Vision))
                        {
                            <div class="col-12">
                                <div class="bg-white p-4 rounded-4 shadow-sm border">
                                    <div class="d-flex align-items-start gap-3">
                                        <div class="text-success fs-2 lh-1"><i class="bi bi-eye"></i></div>
                                        <div>
                                            <h5 class="fw-bold mb-2">Our Vision</h5>
                                            <p class="text-muted mb-0">@cms.Vision</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<!-- Contact Section -->
<section class="pub-section" id="contact">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center mb-5">
                <span class="pub-eyebrow">Get In Touch</span>
                <h2 class="pub-heading">Have Questions? We're Here.</h2>
                <p class="pub-subheading mx-auto">Fill out the form below and our support team will get back to you shortly.</p>
            </div>
        </div>
        
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="pub-contact-form">
                    <form method="post" action="@PubUrl("contact")">
                        @Html.AntiForgeryToken()
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="text" class="form-control pub-input border-0" id="contactName" name="Name" placeholder="Your Name" required>
                                    <label for="contactName" class="text-muted">Your Name</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="email" class="form-control pub-input border-0" id="contactEmail" name="Email" placeholder="Email Address" required>
                                    <label for="contactEmail" class="text-muted">Email Address</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <input type="text" class="form-control pub-input border-0" id="contactSubject" name="Subject" placeholder="Subject" required>
                                    <label for="contactSubject" class="text-muted">Subject</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <textarea class="form-control pub-input border-0" id="contactMessage" name="Message" placeholder="Your Message" style="height: 150px" required></textarea>
                                    <label for="contactMessage" class="text-muted">Your Message</label>
                                </div>
                            </div>
                            <div class="col-12 text-center mt-4">
                                <button type="submit" class="pub-btn-cta px-5 py-3">
                                    Send Message <i class="bi bi-send ms-2"></i>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Smooth scroll for nav links if needed, and simple client-side search logic if desired
        document.getElementById('doctorSearch')?.addEventListener('keyup', function(e) {
            if(e.key === 'Enter' && this.value.trim() !== '') {
                window.location.href = '@PubUrl("doctors")?query=' + encodeURIComponent(this.value);
            }
        });
    </script>
}
