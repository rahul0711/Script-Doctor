@model Pharma_Script.ViewModels.Public.PublicHomeViewModel
@{
    Layout = "~/Views/Public/Shared/_PublicLayout.cshtml";
    var tenant = Model.Tenant;
    var org = tenant.Organization;
    var cms = tenant.CMSSettings;
    var slug = org.OrganizationSlug;
    string PubUrl(string path) => $"/{slug}/{path}".TrimEnd('/');
    var primaryHero = Model.HeroSections.FirstOrDefault();
}

<!-- Hero -->
<section class="pub-hero">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <span class="pub-eyebrow">Welcome to @(cms?.WebsiteTitle ?? org.OrganizationName)</span>
                <h1 class="pub-hero-title mt-2">@(primaryHero?.Title ?? $"Compassionate Care, Right When You Need It")</h1>
                <p class="pub-hero-subtitle">@(primaryHero?.Subtitle ?? "Book appointments with trusted doctors, view specialties, and manage your care - all in one place.")</p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="@(string.IsNullOrEmpty(primaryHero?.ButtonURL) ? PubUrl("doctors") : primaryHero.ButtonURL)" class="pub-btn-cta">
                        @(primaryHero?.ButtonText ?? "Book Appointment")
                    </a>
                    <a href="@PubUrl("doctors")" class="pub-btn-outline">Find a Doctor</a>
                </div>
            </div>
            <div class="col-lg-6">
                @if (!string.IsNullOrEmpty(primaryHero?.BannerImage))
                {
                    <img src="@primaryHero.BannerImage" alt="@primaryHero.Title" class="pub-hero-image" loading="eager" />
                }
                else
                {
                    <div class="pub-hero-image d-flex align-items-center justify-content-center" style="height:340px;background:var(--tenant-primary-soft);">
                        <i class="bi bi-heart-pulse-fill" style="font-size:5rem;color:var(--tenant-primary);"></i>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- Quick Appointment CTA -->
<div class="container">
    <div class="pub-quickbar">
        <div class="row align-items-center g-3">
            <div class="col-12 col-md-8">
                <h5 class="mb-1 fw-bold">Ready to see a doctor?</h5>
                <p class="mb-0 text-muted small">Search by specialty or browse our full list of doctors to book an appointment in minutes.</p>
            </div>
            <div class="col-12 col-md-4 text-md-end">
                <a href="@PubUrl("doctors")" class="pub-btn-cta w-100 w-md-auto d-inline-block text-center">
                    <i class="bi bi-calendar-check me-1"></i>Book Appointment
                </a>
            </div>
        </div>
    </div>
</div>

<!-- About -->
@if (!string.IsNullOrWhiteSpace(cms?.AboutUs) || !string.IsNullOrWhiteSpace(cms?.Mission) || !string.IsNullOrWhiteSpace(cms?.Vision))
{
    <section class="pub-section" id="about">
        <div class="container">
            <div class="row g-5 align-items-start">
                <div class="col-lg-6">
                    <span class="pub-eyebrow">About Us</span>
                    <h2 class="pub-heading mt-2">Caring for you and your family</h2>
                    @if (!string.IsNullOrWhiteSpace(cms?.AboutUs))
                    {
                        <p class="pub-subheading">@cms.AboutUs</p>
                    }
                </div>
                <div class="col-lg-6">
                    <div class="row g-3">
                        @if (!string.IsNullOrWhiteSpace(cms?.Mission))
                        {
                            <div class="col-12">
                                <div class="pub-service-card">
                                    <div class="pub-service-icon"><i class="bi bi-bullseye"></i></div>
                                    <h6 class="fw-bold">Our Mission</h6>
                                    <p class="text-muted small mb-0">@cms.Mission</p>
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(cms?.Vision))
                        {
                            <div class="col-12">
                                <div class="pub-service-card">
                                    <div class="pub-service-icon"><i class="bi bi-eye"></i></div>
                                    <h6 class="fw-bold">Our Vision</h6>
                                    <p class="text-muted small mb-0">@cms.Vision</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<!-- Departments -->
@if (Model.Departments.Any())
{
    <section class="pub-section pub-section-soft">
        <div class="container">
            <div class="text-center mb-5">
                <span class="pub-eyebrow">Specialties</span>
                <h2 class="pub-heading mt-2">Our Departments</h2>
            </div>
            <div class="row g-3">
                @foreach (var dept in Model.Departments)
                {
                    <div class="col-6 col-md-4 col-lg-2">
                        <a href="@PubUrl($"doctors?departmentId={dept.DepartmentID}")" class="pub-dept-pill">
                            <div class="pub-dept-icon"><i class="bi bi-hospital"></i></div>
                            <div class="fw-semibold small">@dept.DepartmentName</div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- Featured Doctors -->
@if (Model.FeaturedDoctors.Any())
{
    <section class="pub-section">
        <div class="container">
            <div class="text-center mb-5">
                <span class="pub-eyebrow">Meet Our Team</span>
                <h2 class="pub-heading mt-2">Featured Doctors</h2>
            </div>
            <div class="row g-4">
                @foreach (var doc in Model.FeaturedDoctors)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="pub-doctor-card">
                            @if (!string.IsNullOrEmpty(doc.ProfileImage))
                            {
                                <img src="@doc.ProfileImage" alt="Dr. @doc.FirstName @doc.LastName" class="pub-doctor-photo" loading="lazy" />
                            }
                            else
                            {
                                <div class="pub-doctor-photo d-flex align-items-center justify-content-center">
                                    <i class="bi bi-person-badge" style="font-size:3rem;color:var(--ink-muted);"></i>
                                </div>
                            }
                            <div class="pub-doctor-body">
                                <div class="pub-doctor-name">Dr. @doc.FirstName @doc.LastName</div>
                                <div class="pub-doctor-meta">@doc.DepartmentName</div>
                                <div class="pub-doctor-meta mb-2">@doc.ExperienceYears yrs experience</div>
                                <span class="pub-fee-badge">₹@doc.ConsultationFee onwards</span>
                                <div class="d-flex gap-2 mt-3">
                                    <a href="@PubUrl($"doctors/{doc.DoctorID}")" class="pub-btn-outline btn-sm flex-fill text-center">View Profile</a>
                                    <a href="@PubUrl($"doctors/{doc.DoctorID}/book")" class="pub-btn-cta btn-sm flex-fill text-center">Book</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="text-center mt-4">
                <a href="@PubUrl("doctors")" class="pub-btn-outline">View All Doctors <i class="bi bi-arrow-right ms-1"></i></a>
            </div>
        </div>
    </section>
}

<!-- Services -->
@if (Model.Services.Any())
{
    <section class="pub-section pub-section-soft" id="services">
        <div class="container">
            <div class="text-center mb-5">
                <span class="pub-eyebrow">What We Offer</span>
                <h2 class="pub-heading mt-2">Our Services</h2>
            </div>
            <div class="row g-4">
                @foreach (var service in Model.Services)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="pub-service-card">
                            @if (!string.IsNullOrEmpty(service.ServiceImage))
                            {
                                <img src="@service.ServiceImage" alt="@service.ServiceName" class="pub-service-image" loading="lazy" />
                            }
                            else
                            {
                                <div class="pub-service-icon"><i class="bi bi-clipboard2-pulse"></i></div>
                            }
                            <h6 class="fw-bold">@service.ServiceName</h6>
                            <p class="text-muted small mb-0">@service.Description</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- Why Choose Us -->
<section class="pub-section">
    <div class="container">
        <div class="text-center mb-5">
            <span class="pub-eyebrow">Why Choose Us</span>
            <h2 class="pub-heading mt-2">Trusted by Patients Every Day</h2>
        </div>
        <div class="row g-4">
            <div class="col-6 col-lg-3">
                <div class="pub-stat">
                    <div class="pub-stat-value">@Model.TotalDoctorCount+</div>
                    <div class="pub-stat-label">Expert Doctors</div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="pub-stat">
                    <div class="pub-stat-value">@Model.Departments.Count+</div>
                    <div class="pub-stat-label">Specialties</div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="pub-stat">
                    <div class="pub-stat-value">24/7</div>
                    <div class="pub-stat-label">Emergency Support</div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="pub-stat">
                    <div class="pub-stat-value"><i class="bi bi-shield-check"></i></div>
                    <div class="pub-stat-label">Verified Specialists</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Gallery Preview -->
@if (Model.GalleryPreview.Any())
{
    <section class="pub-section pub-section-soft" id="gallery">
        <div class="container">
            <div class="text-center mb-5">
                <span class="pub-eyebrow">Take a Look Inside</span>
                <h2 class="pub-heading mt-2">Gallery</h2>
            </div>
            <div class="row g-3">
                @foreach (var image in Model.GalleryPreview)
                {
                    <div class="col-6 col-md-3">
                        <div class="pub-gallery-item">
                            <img src="@image.ImagePath" alt="@(image.ImageTitle ?? "Gallery image")" loading="lazy" />
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- FAQs -->
@if (Model.FAQs.Any())
{
    <section class="pub-section">
        <div class="container">
            <div class="text-center mb-5">
                <span class="pub-eyebrow">Have Questions?</span>
                <h2 class="pub-heading mt-2">Frequently Asked Questions</h2>
            </div>
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="accordion pub-accordion" id="faqAccordion">
                        @for (int i = 0; i < Model.FAQs.Count; i++)
                        {
                            var faq = Model.FAQs[i];
                            <div class="accordion-item">
                                <h2 class="accordion-header">
                                    <button class="accordion-button @(i == 0 ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#faq@(i)">
                                        @faq.Question
                                    </button>
                                </h2>
                                <div id="faq@(i)" class="accordion-collapse collapse @(i == 0 ? "show" : "")" data-bs-parent="#faqAccordion">
                                    <div class="accordion-body text-muted">@faq.Answer</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<!-- Contact CTA -->
<section class="pub-section" id="contact">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-6">
                <div class="pub-contact-cta h-100">
                    <h3 class="fw-bold mb-3">Get in Touch</h3>
                    <p class="mb-4">Have a question or need help booking? Reach out and our team will get back to you shortly.</p>
                    @if (!string.IsNullOrEmpty(cms?.ContactPhone))
                    {
                        <p class="mb-1"><i class="bi bi-telephone-fill me-2"></i>@cms.ContactPhone</p>
                    }
                    @if (!string.IsNullOrEmpty(cms?.ContactEmail))
                    {
                        <p class="mb-3"><i class="bi bi-envelope-fill me-2"></i>@cms.ContactEmail</p>
                    }
                    <a href="@PubUrl("doctors")" class="btn">Book Appointment Instead</a>
                </div>
            </div>
            <div class="col-lg-6">
                <form id="contactForm" asp-route-slug="@slug" asp-controller="PublicContact" asp-action="Submit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="text" name="Website" class="d-none" tabindex="-1" autocomplete="off" />
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <input name="Name" class="form-control" placeholder="Your Name" required />
                        </div>
                        <div class="col-12 col-md-6">
                            <input name="Phone" class="form-control" placeholder="Phone Number" />
                        </div>
                        <div class="col-12">
                            <input name="Email" type="email" class="form-control" placeholder="Email Address" />
                        </div>
                        <div class="col-12">
                            <input name="Subject" class="form-control" placeholder="Subject" />
                        </div>
                        <div class="col-12">
                            <textarea name="Message" class="form-control" rows="4" placeholder="How can we help?" required></textarea>
                        </div>
                        <div class="col-12">
                            <button type="submit" class="pub-btn-cta w-100">Send Message</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@if (!string.IsNullOrEmpty(cms?.GoogleMapEmbed))
{
    <section class="pub-section-tight">
        <div class="container">
            <div class="ratio ratio-21x9 rounded-4 overflow-hidden">
                <iframe src="@cms.GoogleMapEmbed" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        </div>
    </section>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#contactForm').on('submit', function (e) {
                e.preventDefault();
                var form = $(this);
                var btn = form.find('button[type="submit"]');
                var originalHtml = btn.html();
                btn.prop('disabled', true).text('Sending...');

                $.ajax({
                    url: form.attr('action'),
                    type: 'POST',
                    data: form.serialize(),
                    success: function (res) {
                        btn.prop('disabled', false).html(originalHtml);
                        if (res.success) {
                            Swal.fire({ icon: 'success', title: 'Message Sent', text: res.message });
                            form[0].reset();
                        } else {
                            var msg = res.message;
                            if (res.errors && res.errors.length) msg += '\n' + res.errors.join('\n');
                            Swal.fire({ icon: 'error', title: 'Could not send', text: msg });
                        }
                    },
                    error: function () {
                        btn.prop('disabled', false).html(originalHtml);
                        Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong. Please try again.' });
                    }
                });
            });
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
}
