@model Pharma_Script.ViewModels.Public.PublicEditProfileViewModel
@{
    Layout = "~/Views/Public/Shared/_PublicLayout.cshtml";
    var slug = Model.Tenant.Organization.OrganizationSlug;
}

<section class="pub-section-tight pub-section-soft">
    <div class="container">
        <span class="pub-eyebrow">Patient Portal</span>
        <h1 class="pub-heading mt-1" style="font-size:1.8rem;">Edit Profile</h1>
    </div>
</section>

<section class="pub-section">
    <div class="container" style="max-width:680px;">

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <form method="post" asp-action="EditProfile" asp-controller="PublicPatient" asp-route-slug="@slug">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PatientID" />
            <input type="hidden" asp-for="UserID" />

            <div class="pub-service-card mb-4 p-4">
                <h6 class="fw-bold border-bottom pb-2 mb-3">Personal Details</h6>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="FirstName" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="FirstName" class="form-control" required />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="LastName" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="Email" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="Email" type="email" class="form-control" required />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="Phone" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="Phone" type="tel" class="form-control" required />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="DateOfBirth" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="DateOfBirth" type="date" class="form-control" value="@Model.DateOfBirth.ToString("yyyy-MM-dd")" required />
                        <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="Gender" class="form-label small fw-semibold text-secondary"></label>
                        <select asp-for="Gender" class="form-select" required>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="BloodGroup" class="form-label small fw-semibold text-secondary"></label>
                        <select asp-for="BloodGroup" class="form-select">
                            <option value="">-- Not specified --</option>
                            @foreach (var bg in new[] { "A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-" })
                            {
                                <option value="@bg">@bg</option>
                            }
                        </select>
                    </div>
                    <div class="col-6 col-md-3">
                        <label asp-for="Height" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="Height" type="number" step="0.1" min="0" class="form-control" />
                        <span asp-validation-for="Height" class="text-danger small"></span>
                    </div>
                    <div class="col-6 col-md-3">
                        <label asp-for="Weight" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="Weight" type="number" step="0.1" min="0" class="form-control" />
                        <span asp-validation-for="Weight" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="pub-service-card mb-4 p-4">
                <h6 class="fw-bold border-bottom pb-2 mb-3">Address</h6>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Address" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="Address" class="form-control" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="City" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="City" class="form-control" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="State" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="State" class="form-control" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="Country" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="Country" class="form-control" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="Pincode" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="Pincode" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="pub-service-card mb-4 p-4">
                <h6 class="fw-bold border-bottom pb-2 mb-3">Emergency Contact</h6>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="EmergencyContactName" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="EmergencyContactName" class="form-control" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="EmergencyContactNumber" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="EmergencyContactNumber" type="tel" class="form-control" />
                        <span asp-validation-for="EmergencyContactNumber" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="pub-service-card mb-4 p-4">
                <h6 class="fw-bold border-bottom pb-2 mb-3">Change Password</h6>
                <p class="text-muted small">Leave these fields blank to keep your current password.</p>
                <div class="row g-3">
                    <div class="col-12 col-md-4">
                        <label asp-for="CurrentPassword" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="CurrentPassword" type="password" class="form-control" autocomplete="current-password" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="NewPassword" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="NewPassword" type="password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="ConfirmNewPassword" class="form-label small fw-semibold text-secondary"></label>
                        <input asp-for="ConfirmNewPassword" type="password" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3 flex-wrap">
                <button type="submit" class="pub-btn-primary"><i class="bi bi-check-circle me-1"></i>Save Changes</button>
                <a href="/@slug/my/profile" class="pub-btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</section>
