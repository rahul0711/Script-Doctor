@model Pharma_Script.Models.Role

<form asp-action="Edit" asp-controller="Roles" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="RoleID" />

    <div class="row g-3">
        <div class="col-12">
            <label asp-for="RoleName" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="RoleName" class="form-control" />
            <span asp-validation-for="RoleName" class="text-danger small" style="font-size: 0.75rem;"></span>
        </div>

        <div class="col-12">
            <label asp-for="Description" class="form-label small fw-semibold text-secondary"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger small" style="font-size: 0.75rem;"></span>
        </div>
    </div>

    <div class="modal-footer px-0 pb-0 mt-4 border-0">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Update Role</button>
    </div>
</form>
