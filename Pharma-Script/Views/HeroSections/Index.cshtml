@model IEnumerable<Pharma_Script.Models.HeroSection>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Hero Sections";
}

@Html.AntiForgeryToken()
<div class="page-title-box">
    <div>
        <h4 class="page-title">Hero Sections</h4>
        <p class="text-muted small mb-0 font-medium">Manage the banner content shown at the top of your public homepage.</p>
    </div>
    <div>
        <button class="btn btn-primary fw-medium px-3.5 py-2" id="btnCreate">
            <i class="bi bi-plus-lg me-1.5"></i>Add Hero Section
        </button>
    </div>
</div>

<div class="table-card">
    <div class="table-responsive">
        <table class="table custom-table">
            <thead>
                <tr>
                    <th style="width:90px;">Banner</th>
                    <th>Title</th>
                    <th>Subtitle</th>
                    <th>Button</th>
                    <th class="text-center" style="width:100px;">Status</th>
                    <th class="text-end" style="width:120px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.BannerImage))
                                {
                                    <img src="@item.BannerImage" style="width:64px;height:40px;object-fit:cover;border-radius:6px;" />
                                }
                                else
                                {
                                    <span class="text-muted small">&mdash;</span>
                                }
                            </td>
                            <td class="fw-semibold text-dark">@item.Title</td>
                            <td class="text-secondary small">@(string.IsNullOrEmpty(item.Subtitle) ? "&mdash;" : item.Subtitle)</td>
                            <td class="text-secondary small">@item.ButtonText</td>
                            <td class="text-center">
                                <div class="form-check form-switch d-inline-block">
                                    <input class="form-check-input status-toggle" type="checkbox" data-id="@item.HeroSectionID" @(item.IsActive ? "checked" : "") />
                                </div>
                            </td>
                            <td class="text-end">
                                <button class="btn-action btn-action-edit btnEdit" data-id="@item.HeroSectionID"><i class="bi bi-pencil-square"></i></button>
                                <button class="btn-action btn-action-delete btnDelete" data-id="@item.HeroSectionID"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center py-5 text-muted small">No hero sections yet. Add one to introduce your homepage.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="itemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="itemModalLabel">Hero Section</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="itemModalBody"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var modal = new bootstrap.Modal(document.getElementById('itemModal'));

            $('#btnCreate').on('click', function () {
                $('#itemModalLabel').text('Add Hero Section');
                $('#itemModalBody').html('<div class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary"></div></div>');
                modal.show();
                $.get('@Url.Action("Create")', function (html) { $('#itemModalBody').html(html); });
            });

            $(document).on('click', '.btnEdit', function () {
                var id = $(this).data('id');
                $('#itemModalLabel').text('Edit Hero Section');
                $('#itemModalBody').html('<div class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary"></div></div>');
                modal.show();
                $.get('@Url.Action("Edit")/' + id, function (html) { $('#itemModalBody').html(html); });
            });

            $(document).on('submit', '#itemModalBody form', function (e) {
                e.preventDefault();
                var form = $(this);
                var btnSubmit = form.find('button[type="submit"]');
                var originalHtml = btnSubmit.html();
                btnSubmit.html('<span class="spinner-border spinner-border-sm me-1.5"></span>Saving...').prop('disabled', true);

                $.ajax({
                    url: form.attr('action'),
                    type: 'POST',
                    data: new FormData(form[0]),
                    processData: false,
                    contentType: false,
                    success: function (res) {
                        if (res.success) {
                            modal.hide();
                            Swal.fire({ icon: 'success', title: 'Success', text: res.message, timer: 1500, showConfirmButton: false })
                                .then(function () { location.reload(); });
                        } else {
                            btnSubmit.html(originalHtml).prop('disabled', false);
                            var errorMsg = res.message;
                            if (res.errors && res.errors.length > 0) errorMsg += '\n' + res.errors.join('\n');
                            Swal.fire({ icon: 'error', title: 'Validation Error', text: errorMsg });
                        }
                    },
                    error: function () {
                        btnSubmit.html(originalHtml).prop('disabled', false);
                        Swal.fire({ icon: 'error', title: 'System Error', text: 'An unexpected system error occurred.' });
                    }
                });
            });

            $('.status-toggle').on('change', function () {
                var toggle = $(this);
                var id = toggle.data('id');
                var isActive = toggle.is(':checked');
                $.ajax({
                    url: '@Url.Action("ToggleStatus")',
                    type: 'POST',
                    data: { id: id, isActive: isActive, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                    success: function (res) {
                        if (!res.success) { toggle.prop('checked', !isActive); Swal.fire({ icon: 'error', title: 'Action Failed', text: res.message }); }
                    },
                    error: function () { toggle.prop('checked', !isActive); }
                });
            });

            $(document).on('click', '.btnDelete', function () {
                var id = $(this).data('id');
                Swal.fire({
                    title: 'Delete this hero section?', icon: 'warning', showCancelButton: true,
                    confirmButtonColor: '#ef4444', confirmButtonText: 'Yes, Delete'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("Delete")/' + id, type: 'POST',
                            data: { __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                            success: function (res) {
                                if (res.success) { Swal.fire({ icon: 'success', title: 'Deleted', timer: 1200, showConfirmButton: false }).then(function () { location.reload(); }); }
                                else { Swal.fire({ icon: 'error', title: 'Action Failed', text: res.message }); }
                            }
                        });
                    }
                });
            });
        });
    </script>
}
