@model Pharma_Script.ViewModels.CMS.HeroSectionViewModel

<form asp-action="Edit" asp-controller="HeroSections" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="HeroSectionID" />
    <div class="row g-3">
        <div class="col-12">
            <label asp-for="Title" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger small"></span>
        </div>
        <div class="col-12">
            <label asp-for="Subtitle" class="form-label small fw-semibold text-secondary"></label>
            <textarea asp-for="Subtitle" class="form-control" rows="2"></textarea>
        </div>
        <div class="col-12">
            @if (!string.IsNullOrEmpty(Model.ExistingBannerImage))
            {
                <div class="mb-2"><img src="@Model.ExistingBannerImage" style="height:56px;border-radius:6px;" /></div>
            }
            <label asp-for="BannerImage" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="BannerImage" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
            <span class="form-text small">Leave empty to keep the current banner.</span>
        </div>
        <div class="col-12 col-md-6">
            <label asp-for="ButtonText" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="ButtonText" class="form-control" />
        </div>
        <div class="col-12 col-md-6">
            <label asp-for="ButtonURL" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="ButtonURL" class="form-control" />
        </div>
        <div class="col-12">
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label small fw-semibold text-secondary">Active</label>
            </div>
        </div>
    </div>
    <div class="modal-footer px-0 pb-0 mt-4 border-0">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Update Hero Section</button>
    </div>
</form>
