@model Pharma_Script.ViewModels.CMS.HeroSectionViewModel

<form asp-action="Create" asp-controller="HeroSections" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-12">
            <label asp-for="Title" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="Title" class="form-control" placeholder="Compassionate Care, Modern Medicine" />
            <span asp-validation-for="Title" class="text-danger small"></span>
        </div>
        <div class="col-12">
            <label asp-for="Subtitle" class="form-label small fw-semibold text-secondary"></label>
            <textarea asp-for="Subtitle" class="form-control" rows="2" placeholder="Book appointments with top specialists near you"></textarea>
        </div>
        <div class="col-12">
            <label asp-for="BannerImage" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="BannerImage" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
            <span class="form-text small">JPG, PNG, or WEBP. Max 5MB.</span>
        </div>
        <div class="col-12 col-md-6">
            <label asp-for="ButtonText" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="ButtonText" class="form-control" placeholder="Book Appointment" />
        </div>
        <div class="col-12 col-md-6">
            <label asp-for="ButtonURL" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="ButtonURL" class="form-control" placeholder="/doctors" />
        </div>
        <div class="col-12">
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label small fw-semibold text-secondary">Active</label>
            </div>
        </div>
    </div>
    <div class="modal-footer px-0 pb-0 mt-4 border-0">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Hero Section</button>
    </div>
</form>
