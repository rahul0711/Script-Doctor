@model IEnumerable<Pharma_Script.Models.Patient>
@using Pharma_Script.Helpers
@{
    Layout = "_Layout";
    ViewData["Title"] = "Patient Registry";
}

<div class="page-title-box d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h4 class="page-title mb-1">Patient Registry</h4>
        <p class="text-muted small mb-0">Search, register, and manage electronic health records (EHR) of patients.</p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <button class="btn btn-primary fw-medium px-4 shadow-sm" style="border-radius: 8px;" id="btnCreatePatient">
            <i class="bi bi-plus-lg me-1.5"></i>Register Patient
        </button>
    </div>
</div>

<div class="table-card mb-4">
    <div class="table-card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 bg-white">
        <h5 class="table-card-title mb-0"><i class="bi bi-people me-2 text-primary"></i>EHR Profiles</h5>
        
        <!-- Filters Form -->
        <form method="get" action="@Url.Action("Index")" class="d-flex flex-wrap gap-2">
            <div class="input-group input-group-sm shadow-sm" style="width: 220px; border-radius: 6px; overflow: hidden;">
                <span class="input-group-text bg-light border-light text-muted border-0"><i class="bi bi-search"></i></span>
                <input type="text" name="searchTerm" class="form-control bg-light border-light border-0 shadow-none" placeholder="Search patient..." value="@ViewBag.SearchTerm" />
            </div>
            
            @if (ViewBag.Organizations != null)
            {
                <select name="orgIdFilter" class="form-select form-select-sm bg-light border-light shadow-sm" asp-items="@ViewBag.Organizations" style="width: 180px; border-radius: 6px;">
                    <option value="">All Organizations</option>
                </select>
            }
            <select name="branchId" class="form-select form-select-sm bg-light border-light shadow-sm" asp-items="@ViewBag.Branches" style="width: 180px; border-radius: 6px;">
                <option value="">All Branches</option>
            </select>
            <button type="submit" class="btn btn-primary btn-sm px-3 shadow-sm" style="border-radius: 6px;"><i class="bi bi-funnel"></i></button>
            <a href="@Url.Action("Index")" class="btn btn-light btn-sm px-3 shadow-sm text-secondary" style="border-radius: 6px;"><i class="bi bi-arrow-counterclockwise"></i></a>
        </form>
    </div>

    <div class="table-responsive">
        <table class="table custom-table align-middle">
            <thead>
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>Patient Name</th>
                    <th>Date of Birth / Age</th>
                    <th>Gender / Blood</th>
                    <th>Contact details</th>
                    <th class="text-center" style="width: 100px;">Status</th>
                    <th class="text-end" style="width: 180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        var age = DateTime.Today.Year - item.DateOfBirth.Year;
                        if (item.DateOfBirth.Date > DateTime.Today.AddYears(-age)) age--;
                        <tr>
                            <td class="text-muted small">@item.PatientID</td>
                            <td class="fw-semibold text-dark">
                                <div class="d-flex align-items-center gap-2.5">
                                    <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; font-weight: 700; font-size: 0.9rem;">
                                        @item.FirstName[0]
                                    </div>
                                    <div>
                                        <div class="btnDoctorHistory text-primary text-decoration-none" data-id="@item.PatientID" style="cursor:pointer; font-weight:600; font-size:0.9rem;" title="View Doctors Visited">
                                            @item.FirstName @item.LastName
                                        </div>
                                        <div class="text-muted text-truncate mt-0.5" style="font-size: 0.72rem; max-width:180px;"><i class="bi bi-geo-alt me-1 opacity-50"></i>@(item.BranchName ?? "Global")</div>
                                    </div>
                                </div>
                            </td>
                            <td class="small text-dark">
                                <div class="fw-medium">@item.DateOfBirth.ToString("dd MMM yyyy")</div>
                                <div class="text-muted mt-0.5" style="font-size: 0.72rem;">@age Years Old</div>
                            </td>
                            <td class="small">
                                <div class="fw-medium text-dark">@item.Gender</div>
                                <div class="text-muted mt-0.5" style="font-size: 0.72rem;"><i class="bi bi-droplet me-1 text-danger opacity-50"></i>@(item.BloodGroup ?? "Not Set")</div>
                            </td>
                            <td class="small text-secondary">
                                <div class="text-truncate" style="max-width:160px;"><i class="bi bi-envelope text-muted me-1.5 opacity-50"></i>@item.Email</div>
                                <div class="mt-0.5"><i class="bi bi-telephone text-muted me-1.5 opacity-50"></i>@item.Phone</div>
                            </td>
                            <td class="text-center">
                                <div class="form-check form-switch d-inline-block">
                                    <input class="form-check-input status-toggle" type="checkbox" data-id="@item.PatientID" @(item.IsActive ? "checked" : "") style="cursor: pointer;" />
                                </div>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-1.5">
                                    <a class="btn btn-light btn-sm text-primary px-2 border-0 bg-primary bg-opacity-10 shadow-none" href="@Url.Action("Details", "Patients", new { id = item.PatientID })" title="Electronic Health Record (EHR) Page">
                                        <i class="bi bi-card-heading"></i>
                                    </a>
                                    <button class="btn btn-light btn-sm text-secondary px-2 border-0 shadow-none btnEdit" data-id="@item.PatientID" title="Edit Profile">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="btn btn-light btn-sm text-danger px-2 border-0 bg-danger bg-opacity-10 shadow-none btnDelete" data-id="@item.PatientID" title="Delete Profile">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5">
                            <div class="text-muted mb-2"><i class="bi bi-person-x" style="font-size: 3rem;"></i></div>
                            <h6 class="text-dark">No patient profiles found.</h6>
                            <p class="text-muted small">Register a new patient or adjust your search filters.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="card-footer border-0 bg-white py-3 px-4 d-flex justify-content-between align-items-center">
            <div class="small text-muted fw-medium">
                Showing page @ViewBag.CurrentPage of @ViewBag.TotalPages (@ViewBag.TotalItems records)
            </div>
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0 gap-1">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link rounded-2 border-0 bg-light text-dark" href="@Url.Action("Index", new { searchTerm = ViewBag.SearchTerm, branchId = ViewBag.SelectedBranch, page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize })">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                            <a class="page-link rounded-2 border-0 @(ViewBag.CurrentPage == i ? "bg-primary text-white" : "bg-light text-dark")" href="@Url.Action("Index", new { searchTerm = ViewBag.SearchTerm, branchId = ViewBag.SelectedBranch, page = i, pageSize = ViewBag.PageSize })">@i</a>
                        </li>
                    }
                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link rounded-2 border-0 bg-light text-dark" href="@Url.Action("Index", new { searchTerm = ViewBag.SearchTerm, branchId = ViewBag.SelectedBranch, page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize })">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Modal -->
<div class="modal fade" id="patientModal" tabindex="-1" aria-labelledby="patientModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="patientModalLabel">Patient Registration</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="patientModalBody">
                <!-- Content loaded dynamically -->
            </div>
        </div>
    </div>
</div>

<!-- Doctor History Offcanvas Drawer -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="doctorHistoryDrawer" aria-labelledby="doctorHistoryLabel" style="width: 440px; max-width: 95vw;">
    <div class="offcanvas-header" style="border-bottom: 1px solid #e2e8f0; padding: 0.9rem 1.25rem;">
        <h6 class="offcanvas-title fw-semibold" id="doctorHistoryLabel" style="font-size:0.9rem;">
            <i class="bi bi-person-lines-fill me-2 text-primary"></i>Doctors Visited
        </h6>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body p-0" id="doctorHistoryBody" style="overflow-y: auto;">
        <div class="text-center py-5 text-muted">
            <div class="spinner-border spinner-border-sm text-primary mb-2" role="status"></div>
            <p class="small mb-0">Loading history...</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var modal = new bootstrap.Modal(document.getElementById('patientModal'));

            // Load Create
            $('#btnCreatePatient').on('click', function () {
                $('#patientModalLabel').text('Register Patient Record');
                $('#patientModalBody').html('<div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary" role="status"></div></div>');
                modal.show();

                $.get('@Url.Action("Create")', function (html) {
                    $('#patientModalBody').html(html);
                    $.validator.unobtrusive.parse('#patientModalBody');
                });
            });

            // Load Edit
            $(document).on('click', '.btnEdit', function () {
                var id = $(this).data('id');
                $('#patientModalLabel').text('Edit Patient Profile');
                $('#patientModalBody').html('<div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary" role="status"></div></div>');
                modal.show();

                $.get('@Url.Action("Edit")/' + id, function (html) {
                    $('#patientModalBody').html(html);
                    $.validator.unobtrusive.parse('#patientModalBody');
                });
            });

            // Form Submit via AJAX
            $(document).on('submit', '#patientModalBody form', function (e) {
                e.preventDefault();
                var form = $(this);
                if (!form.valid()) return false;

                var btnSubmit = form.find('button[type="submit"]');
                var originalHtml = btnSubmit.html();
                btnSubmit.html('<span class="spinner-border spinner-border-sm me-1" role="status"></span>Saving...').prop('disabled', true);

                $.ajax({
                    url: form.attr('action'),
                    type: form.attr('method'),
                    data: form.serialize(),
                    success: function (res) {
                        if (res.success) {
                            modal.hide();
                            Swal.fire({
                                icon: 'success',
                                title: 'Success',
                                text: res.message,
                                timer: 1500,
                                showConfirmButton: false
                            }).then(function () {
                                location.reload();
                            });
                        } else {
                            btnSubmit.html(originalHtml).prop('disabled', false);
                            Swal.fire({
                                icon: 'error',
                                title: 'Validation Error',
                                text: res.message
                            });
                        }
                    },
                    error: function () {
                        btnSubmit.html(originalHtml).prop('disabled', false);
                        Swal.fire({
                            icon: 'error',
                            title: 'System Error',
                            text: 'An unexpected system error occurred.'
                        });
                    }
                });
            });

            // Toggle active status
            $('.status-toggle').on('change', function () {
                var toggle = $(this);
                var id = toggle.data('id');
                var isActive = toggle.is(':checked');

                $.ajax({
                    url: '@Url.Action("ToggleStatus")',
                    type: 'POST',
                    data: {
                        id: id,
                        isActive: isActive,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (res) {
                        if (res.success) {
                            const Toast = Swal.mixin({
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 2000,
                                timerProgressBar: true
                            });
                            Toast.fire({
                                icon: 'success',
                                title: res.message
                            });
                        } else {
                            toggle.prop('checked', !isActive);
                            Swal.fire({
                                icon: 'error',
                                title: 'Action Failed',
                                text: res.message
                            });
                        }
                    },
                    error: function () {
                        toggle.prop('checked', !isActive);
                        Swal.fire({
                            icon: 'error',
                            title: 'Connection Error',
                            text: 'Failed to update patient status.'
                        });
                    }
                });
            });

            // Delete patient
            $(document).on('click', '.btnDelete', function () {
                var id = $(this).data('id');

                Swal.fire({
                    title: 'Delete Patient Record?',
                    text: "All medical histories, vitals logs, and uploaded files will be archived. This cannot be undone.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#64748b',
                    confirmButtonText: 'Yes, Delete',
                    cancelButtonText: 'Cancel'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("Delete")/' + id,
                            type: 'POST',
                            data: {
                                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                            },
                            success: function (res) {
                                if (res.success) {
                                    Swal.fire({
                                        icon: 'success',
                                        title: 'Deleted',
                                        text: res.message,
                                        timer: 1500,
                                        showConfirmButton: false
                                    }).then(function () {
                                        location.reload();
                                    });
                                } else {
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Action Failed',
                                        text: res.message
                                    });
                                }
                            },
                            error: function () {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Connection Error',
                                    text: 'Failed to delete patient.'
                                });
                            }
                        });
                    }
                });
            });

            // Open Doctor History Drawer on patient name click
            var historyDrawer = new bootstrap.Offcanvas(document.getElementById('doctorHistoryDrawer'));
            $(document).on('click', '.btnDoctorHistory', function () {
                var id = $(this).data('id');
                $('#doctorHistoryLabel').html('<i class="bi bi-person-lines-fill me-2 text-primary"></i>Doctors Visited');
                $('#doctorHistoryBody').html('<div class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-primary mb-2" role="status"></div><p class="small mb-0">Loading history...</p></div>');
                historyDrawer.show();
                $.get('@Url.Action("DoctorHistory", "Patients")/' + id, function (html) {
                    $('#doctorHistoryBody').html(html);
                }).fail(function () {
                    $('#doctorHistoryBody').html('<div class="text-center py-5 text-danger small"><i class="bi bi-exclamation-circle d-block fs-3 mb-2"></i>Failed to load history.</div>');
                });
            });
        });
    </script>
}
