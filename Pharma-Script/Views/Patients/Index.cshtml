@model IEnumerable<Pharma_Script.Models.Patient>
@using Pharma_Script.Helpers
@{
    Layout = "_Layout";
    ViewData["Title"] = "Patient Registry";
}

<div class="page-title-box">
    <div>
        <h4 class="page-title">Patient Registry</h4>
        <p class="text-muted small mb-0 font-medium">Search, register, and manage electronic health records (EHR) of patients.</p>
    </div>
    <div>
        <button class="btn btn-primary fw-medium px-3.5 py-2" id="btnCreatePatient">
            <i class="bi bi-plus-lg me-1.5"></i>Register Patient
        </button>
    </div>
</div>

<div class="table-card mb-4">
    <div class="table-card-header flex-column flex-md-row gap-3">
        <h5 class="table-card-title mb-0">EHR Profiles</h5>
        
        <!-- Filters Form -->
        <form method="get" action="@Url.Action("Index")" class="d-flex gap-2">
            <input type="text" name="searchTerm" class="form-control form-control-sm" placeholder="Search patient..." value="@ViewBag.SearchTerm" style="width: 220px;" />
            <select name="branchId" class="form-select form-select-sm" asp-items="@ViewBag.Branches" style="width: 180px;">
                <option value="">All Branches</option>
            </select>
            <button type="submit" class="btn btn-primary btn-sm px-2.5"><i class="bi bi-search"></i></button>
            <a href="@Url.Action("Index")" class="btn btn-light btn-sm px-2.5"><i class="bi bi-arrow-counterclockwise"></i></a>
        </form>
    </div>

    <div class="table-responsive">
        <table class="table custom-table">
            <thead>
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>Patient Name</th>
                    <th>Date of Birth / Age</th>
                    <th>Gender / Blood</th>
                    <th>Contact details</th>
                    <th class="text-center" style="width: 100px;">Status</th>
                    <th class="text-end" style="width: 200px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        var age = DateTime.Today.Year - item.DateOfBirth.Year;
                        if (item.DateOfBirth.Date > DateTime.Today.AddYears(-age)) age--;
                        <tr>
                            <td>@item.PatientID</td>
                            <td class="fw-semibold text-dark">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle bg-light text-primary d-flex align-items-center justify-content-center border" style="width: 32px; height: 32px; font-weight: bold; font-size: 0.85rem;">
                                        @item.FirstName[0]
                                    </div>
                                    <div>
                                        <div>@item.FirstName @item.LastName</div>
                                        <div class="text-muted small" style="font-size: 0.72rem;">@(item.BranchName ?? "N/A")</div>
                                    </div>
                                </div>
                            </td>
                            <td class="small fw-semibold text-dark">
                                @item.DateOfBirth.ToString("dd MMM yyyy")
                                <div class="text-muted small fw-normal" style="font-size: 0.72rem;">@age Years Old</div>
                            </td>
                            <td class="small">
                                <div class="fw-semibold text-secondary">@item.Gender</div>
                                <div class="text-muted" style="font-size: 0.72rem;">Blood Group: @(item.BloodGroup ?? "Not Set")</div>
                            </td>
                            <td class="small text-secondary">
                                <div><i class="bi bi-envelope text-muted me-1.5"></i>@item.Email</div>
                                <div><i class="bi bi-telephone text-muted me-1.5"></i>@item.Phone</div>
                            </td>
                            <td class="text-center">
                                <div class="form-check form-switch d-inline-block">
                                    <input class="form-check-input status-toggle" type="checkbox" data-id="@item.PatientID" @(item.IsActive ? "checked" : "") style="cursor: pointer;" />
                                </div>
                            </td>
                            <td class="text-end">
                                <a class="btn-action" href="@Url.Action("Details", "Patients", new { id = item.PatientID })" title="Electronic Health Record (EHR) Page">
                                    <i class="bi bi-card-heading"></i>
                                </a>
                                <button class="btn-action btn-action-edit btnEdit" data-id="@item.PatientID" title="Edit Profile">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                                <button class="btn-action btn-action-delete btnDelete" data-id="@item.PatientID" title="Delete Profile">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted small">No patient profiles found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="pagination-container">
            <div class="pagination-info">
                Showing page @ViewBag.CurrentPage of @ViewBag.TotalPages (@ViewBag.TotalItems records)
            </div>
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { searchTerm = ViewBag.SearchTerm, branchId = ViewBag.SelectedBranch, page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize })">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { searchTerm = ViewBag.SearchTerm, branchId = ViewBag.SelectedBranch, page = i, pageSize = ViewBag.PageSize })">@i</a>
                        </li>
                    }
                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { searchTerm = ViewBag.SearchTerm, branchId = ViewBag.SelectedBranch, page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize })">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Modal -->
<div class="modal fade" id="patientModal" tabindex="-1" aria-labelledby="patientModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="patientModalLabel">Patient Registration</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="patientModalBody">
                <!-- Content loaded dynamically -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var modal = new bootstrap.Modal(document.getElementById('patientModal'));

            // Load Create
            $('#btnCreatePatient').on('click', function () {
                $('#patientModalLabel').text('Register Patient Record');
                $('#patientModalBody').html('<div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary" role="status"></div></div>');
                modal.show();

                $.get('@Url.Action("Create")', function (html) {
                    $('#patientModalBody').html(html);
                    $.validator.unobtrusive.parse('#patientModalBody');
                });
            });

            // Load Edit
            $(document).on('click', '.btnEdit', function () {
                var id = $(this).data('id');
                $('#patientModalLabel').text('Edit Patient Profile');
                $('#patientModalBody').html('<div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary" role="status"></div></div>');
                modal.show();

                $.get('@Url.Action("Edit")/' + id, function (html) {
                    $('#patientModalBody').html(html);
                    $.validator.unobtrusive.parse('#patientModalBody');
                });
            });

            // Form Submit via AJAX
            $(document).on('submit', '#patientModalBody form', function (e) {
                e.preventDefault();
                var form = $(this);
                if (!form.valid()) return false;

                var btnSubmit = form.find('button[type="submit"]');
                var originalHtml = btnSubmit.html();
                btnSubmit.html('<span class="spinner-border spinner-border-sm me-1" role="status"></span>Saving...').prop('disabled', true);

                $.ajax({
                    url: form.attr('action'),
                    type: form.attr('method'),
                    data: form.serialize(),
                    success: function (res) {
                        if (res.success) {
                            modal.hide();
                            Swal.fire({
                                icon: 'success',
                                title: 'Success',
                                text: res.message,
                                timer: 1500,
                                showConfirmButton: false
                            }).then(function () {
                                location.reload();
                            });
                        } else {
                            btnSubmit.html(originalHtml).prop('disabled', false);
                            Swal.fire({
                                icon: 'error',
                                title: 'Validation Error',
                                text: res.message
                            });
                        }
                    },
                    error: function () {
                        btnSubmit.html(originalHtml).prop('disabled', false);
                        Swal.fire({
                            icon: 'error',
                            title: 'System Error',
                            text: 'An unexpected system error occurred.'
                        });
                    }
                });
            });

            // Toggle active status
            $('.status-toggle').on('change', function () {
                var toggle = $(this);
                var id = toggle.data('id');
                var isActive = toggle.is(':checked');

                $.ajax({
                    url: '@Url.Action("ToggleStatus")',
                    type: 'POST',
                    data: {
                        id: id,
                        isActive: isActive,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (res) {
                        if (res.success) {
                            const Toast = Swal.mixin({
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 2000,
                                timerProgressBar: true
                            });
                            Toast.fire({
                                icon: 'success',
                                title: res.message
                            });
                        } else {
                            toggle.prop('checked', !isActive);
                            Swal.fire({
                                icon: 'error',
                                title: 'Action Failed',
                                text: res.message
                            });
                        }
                    },
                    error: function () {
                        toggle.prop('checked', !isActive);
                        Swal.fire({
                            icon: 'error',
                            title: 'Connection Error',
                            text: 'Failed to update patient status.'
                        });
                    }
                });
            });

            // Delete patient
            $(document).on('click', '.btnDelete', function () {
                var id = $(this).data('id');

                Swal.fire({
                    title: 'Delete Patient Record?',
                    text: "All medical histories, vitals logs, and uploaded files will be archived. This cannot be undone.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#64748b',
                    confirmButtonText: 'Yes, Delete',
                    cancelButtonText: 'Cancel'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("Delete")/' + id,
                            type: 'POST',
                            data: {
                                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                            },
                            success: function (res) {
                                if (res.success) {
                                    Swal.fire({
                                        icon: 'success',
                                        title: 'Deleted',
                                        text: res.message,
                                        timer: 1500,
                                        showConfirmButton: false
                                    }).then(function () {
                                        location.reload();
                                    });
                                } else {
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Action Failed',
                                        text: res.message
                                    });
                                }
                            },
                            error: function () {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Connection Error',
                                    text: 'Failed to delete patient.'
                                });
                            }
                        });
                    }
                });
            });
        });
    </script>
}
