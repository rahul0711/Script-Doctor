@model Pharma_Script.ViewModels.CMS.GalleryImageViewModel

<form asp-action="Create" asp-controller="Gallery" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-12">
            <label asp-for="ImageFile" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="ImageFile" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" required />
            <span class="form-text small">JPG, PNG, or WEBP. Max 5MB.</span>
        </div>
        <div class="col-12 col-md-8">
            <label asp-for="ImageTitle" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="ImageTitle" class="form-control" placeholder="Reception Area" />
        </div>
        <div class="col-12 col-md-4">
            <label asp-for="DisplayOrder" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="DisplayOrder" type="number" min="1" class="form-control" />
        </div>
        <div class="col-12">
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label small fw-semibold text-secondary">Active</label>
            </div>
        </div>
    </div>
    <div class="modal-footer px-0 pb-0 mt-4 border-0">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Upload</button>
    </div>
</form>
