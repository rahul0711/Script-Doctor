@model IEnumerable<Pharma_Script.Models.Doctor>
@using Pharma_Script.Helpers
@{
    Layout = "_Layout";
    ViewData["Title"] = "Doctor Management";
}

<div class="page-title-box d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h4 class="page-title mb-1">Doctor Management</h4>
        <p class="text-muted small mb-0">Manage clinical practitioners, specializations, schedules, and leaves.</p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <button class="btn btn-primary fw-medium px-4 shadow-sm" style="border-radius: 8px;" id="btnCreateDoctor">
            <i class="bi bi-plus-lg me-1.5"></i>Add Doctor
        </button>
    </div>
</div>

<div class="table-card mb-4">
    <div class="table-card-header d-flex flex-column align-items-center gap-3 bg-white p-4">
        <div class="d-flex align-items-center justify-content-center gap-2 w-100 mb-1">
            <span class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded" style="width: 32px; height: 32px;">
                <i class="bi bi-person-badge" style="font-size: 1.15rem;"></i>
            </span>
            <h5 class="table-card-title mb-0" style="font-size: 1.15rem; font-weight: 700; color: #1e293b;">Doctors List</h5>
        </div>
        
        <!-- Filters Form -->
        <form method="get" action="@Url.Action("Index")" class="doctor-filter-form">
            <div class="filter-search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" name="searchTerm" class="form-control shadow-none" placeholder="Search doctor..." value="@ViewBag.SearchTerm" />
            </div>
            @if (ViewBag.Organizations != null)
            {
                <div class="filter-select-wrap">
                    <select name="orgIdFilter" class="form-select shadow-none" asp-items="@ViewBag.Organizations">
                        <option value="">All Organizations</option>
                    </select>
                </div>
            }
            <div class="filter-select-wrap">
                <select name="branchId" class="form-select shadow-none" asp-items="@ViewBag.Branches">
                    <option value="">All Branches</option>
                </select>
            </div>
            <div class="filter-select-wrap">
                <select name="departmentId" class="form-select shadow-none" asp-items="@ViewBag.Departments">
                    <option value="">All Departments</option>
                </select>
            </div>
            <div class="filter-select-wrap">
                <select name="specializationId" class="form-select shadow-none" asp-items="@ViewBag.Specializations">
                    <option value="">All Specializations</option>
                </select>
            </div>
            <!-- <div class="filter-select-wrap">
                <select name="isActive" class="form-select shadow-none" asp-items="@ViewBag.ActiveStatusList">
                    <option value="">All Statuses</option>
                </select>
            </div> -->
            <div class="filter-buttons-wrap">
                <button type="submit" class="btn btn-filter" title="Filter"><i class="bi bi-funnel"></i></button>
                <a href="@Url.Action("Index")" class="btn btn-reset text-secondary" title="Reset"><i class="bi bi-arrow-counterclockwise"></i></a>
            </div>
        </form>
    </div>

    <div class="table-responsive">
        <table class="table custom-table align-middle">
            <thead>
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>Doctor Name</th>
                    <th>Qualification</th>
                    <th>Branch / Department</th>
                    <th>Specializations</th>
                    <th class="text-end" style="width: 120px;">Reg. Fee</th>
                    <th class="text-center" style="width: 100px;">Status</th>
                    <th class="text-end" style="width: 220px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-muted" style="font-size: 0.875rem;">@item.DoctorID</td>
                            <td class="fw-semibold text-dark">
                                <div class="d-flex align-items-center gap-2.5">
                                    @if (!string.IsNullOrEmpty(item.ProfileImage))
                                    {
                                        <img src="@item.ProfileImage" class="rounded-circle border" style="width: 36px; height: 36px; object-fit: cover;" alt="@item.FirstName" />
                                    }
                                    else
                                    {
                                        <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; font-weight: 700; font-size: 0.9rem;">
                                            @item.FirstName[0]
                                        </div>
                                    }
                                    <div>
                                        <div class="btnStats text-primary text-decoration-none" data-id="@item.DoctorID" style="cursor:pointer; font-weight:600; font-size:0.9rem;" title="View Stats & Appointments">
                                            Dr. @item.FirstName @item.LastName
                                            <i class="bi bi-bar-chart-line ms-1 opacity-75" style="font-size:0.75rem;"></i>
                                        </div>
                                        <div class="text-muted small mt-0.5" style="font-size: 0.75rem;">@item.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="fw-semibold text-dark" style="font-size: 0.875rem;">@item.Qualification</div>
                                <div class="text-muted mt-0.5" style="font-size: 0.75rem;">@item.ExperienceYears Years Exp.</div>
                            </td>
                            <td>
                                <div class="fw-semibold text-dark" style="font-size: 0.875rem;">@(item.BranchName ?? "Global")</div>
                                <div class="text-muted mt-0.5" style="font-size: 0.75rem;">@(item.DepartmentName ?? "N/A")</div>
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-1">
                                    @if (item.SpecializationNames != null)
                                    {
                                        foreach (var spec in item.SpecializationNames)
                                        {
                                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-2.5 py-1 border-0" style="font-size: 0.7rem; font-weight: 500;">@spec</span>
                                        }
                                    }
                                </div>
                            </td>
                            <td class="text-end fw-semibold text-dark text-nowrap">₹@item.ConsultationFee.ToString("F2")</td>
                            <td class="text-center">
                                <div class="form-check form-switch d-inline-block">
                                    <input class="form-check-input status-toggle" type="checkbox" data-id="@item.DoctorID" @(item.IsActive ? "checked" : "") style="cursor: pointer;" />
                                </div>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-1.5">
                                    <a class="btn btn-light btn-sm text-primary px-2 border-0 bg-primary bg-opacity-10 shadow-none" href="@Url.Action("Schedule", "DoctorAvailability", new { doctorId = item.DoctorID })" title="Weekly Availability">
                                        <i class="bi bi-clock"></i>
                                    </a>
                                    <a class="btn btn-light btn-sm text-warning px-2 border-0 bg-warning bg-opacity-10 shadow-none" href="@Url.Action("Index", "DoctorLeave", new { doctorId = item.DoctorID })" title="Leaves Schedule">
                                        <i class="bi bi-calendar-event"></i>
                                    </a>
                                    <button class="btn btn-light btn-sm text-secondary px-2 border-0 shadow-none btnView" data-id="@item.DoctorID" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <button class="btn btn-light btn-sm text-dark px-2 border-0 bg-light shadow-none btnEdit" data-id="@item.DoctorID" title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="btn btn-light btn-sm text-danger px-2 border-0 bg-danger bg-opacity-10 shadow-none btnDelete" data-id="@item.DoctorID" title="Delete Doctor">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center py-5">
                            <div class="text-muted mb-2"><i class="bi bi-person-x" style="font-size: 3rem;"></i></div>
                            <h6 class="text-dark">No doctors found matching filters.</h6>
                            <p class="text-muted small">Register a new practitioner or adjust search settings.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="card-footer border-0 bg-white py-3 px-4 d-flex justify-content-between align-items-center">
            <div class="small text-muted fw-medium">
                Showing page @ViewBag.CurrentPage of @ViewBag.TotalPages (@ViewBag.TotalItems records)
            </div>
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0 gap-1">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link rounded-2 border-0 bg-light text-dark" href="@Url.Action("Index", new { searchTerm = ViewBag.SearchTerm, branchId = ViewBag.SelectedBranch, departmentId = ViewBag.SelectedDepartment, specializationId = ViewBag.SelectedSpecialization, isActive = ViewBag.SelectedStatus, page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize })">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                            <a class="page-link rounded-2 border-0 @(ViewBag.CurrentPage == i ? "bg-primary text-white" : "bg-light text-dark")" href="@Url.Action("Index", new { searchTerm = ViewBag.SearchTerm, branchId = ViewBag.SelectedBranch, departmentId = ViewBag.SelectedDepartment, specializationId = ViewBag.SelectedSpecialization, isActive = ViewBag.SelectedStatus, page = i, pageSize = ViewBag.PageSize })">@i</a>
                        </li>
                    }
                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link rounded-2 border-0 bg-light text-dark" href="@Url.Action("Index", new { searchTerm = ViewBag.SearchTerm, branchId = ViewBag.SelectedBranch, departmentId = ViewBag.SelectedDepartment, specializationId = ViewBag.SelectedSpecialization, isActive = ViewBag.SelectedStatus, page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize })">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Modal -->
<div class="modal fade" id="doctorModal" tabindex="-1" aria-labelledby="doctorModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="doctorModalLabel">Doctor Settings</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="doctorModalBody">
                <!-- Content loaded dynamically -->
            </div>
        </div>
    </div>
</div>

<!-- Stats Offcanvas Drawer -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="statsPanelDrawer" aria-labelledby="statsPanelLabel" style="width: 420px; max-width: 95vw;">
    <div class="offcanvas-header" style="border-bottom: 1px solid #e2e8f0; padding: 0.9rem 1.25rem;">
        <h6 class="offcanvas-title fw-semibold" id="statsPanelLabel" style="font-size:0.9rem;">
            <i class="bi bi-bar-chart-line me-2 text-primary"></i>Doctor Stats & History
        </h6>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body p-0" id="statsPanelBody" style="overflow-y: auto;">
        <div class="text-center py-5 text-muted">
            <div class="spinner-border spinner-border-sm text-primary mb-2" role="status"></div>
            <p class="small mb-0">Loading stats...</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var modal = new bootstrap.Modal(document.getElementById('doctorModal'));

            // Load Create
            $('#btnCreateDoctor').on('click', function () {
                $('#doctorModalLabel').text('Create Doctor Profile');
                $('#doctorModalBody').html('<div class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary" role="status"></div><p class="mt-2 text-muted small">Loading form...</p></div>');
                modal.show();

                $.get('@Url.Action("Create")', function (html) {
                    $('#doctorModalBody').html(html);
                    $.validator.unobtrusive.parse('#doctorModalBody');
                });
            });

            // Load Edit
            $(document).on('click', '.btnEdit', function () {
                var id = $(this).data('id');
                $('#doctorModalLabel').text('Edit Doctor Profile');
                $('#doctorModalBody').html('<div class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary" role="status"></div><p class="mt-2 text-muted small">Loading settings...</p></div>');
                modal.show();

                $.get('@Url.Action("Edit")/' + id, function (html) {
                    $('#doctorModalBody').html(html);
                    $.validator.unobtrusive.parse('#doctorModalBody');
                });
            });

            // Load Details
            $(document).on('click', '.btnView', function () {
                var id = $(this).data('id');
                $('#doctorModalLabel').text('Doctor Profile Details');
                $('#doctorModalBody').html('<div class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary" role="status"></div><p class="mt-2 text-muted small">Loading details...</p></div>');
                modal.show();

                $.get('@Url.Action("Details")/' + id, function (html) {
                    $('#doctorModalBody').html(html);
                });
            });

            // Form Submit via AJAX
            $(document).on('submit', '#doctorModalBody form', function (e) {
                e.preventDefault();
                var form = $(this);
                if (!form.valid()) return false;

                var btnSubmit = form.find('button[type="submit"]');
                var originalHtml = btnSubmit.html();
                btnSubmit.html('<span class="spinner-border spinner-border-sm me-1.5" role="status"></span>Saving...').prop('disabled', true);

                $.ajax({
                    url: form.attr('action'),
                    type: form.attr('method'),
                    data: new FormData(form[0]),
                    processData: false,
                    contentType: false,
                    success: function (res) {
                        if (res.success) {
                            modal.hide();
                            Swal.fire({
                                icon: 'success',
                                title: 'Success',
                                text: res.message,
                                timer: 1500,
                                showConfirmButton: false
                            }).then(function () {
                                location.reload();
                            });
                        } else {
                            btnSubmit.html(originalHtml).prop('disabled', false);
                            var errorMsg = res.message;
                            if (res.errors && res.errors.length > 0) {
                                errorMsg += '\n' + res.errors.join('\n');
                            }
                            Swal.fire({
                                icon: 'error',
                                title: 'Validation Error',
                                text: errorMsg
                            });
                        }
                    },
                    error: function () {
                        btnSubmit.html(originalHtml).prop('disabled', false);
                        Swal.fire({
                            icon: 'error',
                            title: 'System Error',
                            text: 'An unexpected system error occurred.'
                        });
                    }
                });
            });

            // Toggle active status
            $('.status-toggle').on('change', function () {
                var toggle = $(this);
                var id = toggle.data('id');
                var isActive = toggle.is(':checked');

                $.ajax({
                    url: '@Url.Action("ToggleStatus")',
                    type: 'POST',
                    data: {
                        id: id,
                        isActive: isActive,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (res) {
                        if (res.success) {
                            const Toast = Swal.mixin({
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 2000,
                                timerProgressBar: true
                            });
                            Toast.fire({
                                icon: 'success',
                                title: res.message
                            });
                        } else {
                            toggle.prop('checked', !isActive);
                            Swal.fire({
                                icon: 'error',
                                title: 'Action Failed',
                                text: res.message
                            });
                        }
                    },
                    error: function () {
                        toggle.prop('checked', !isActive);
                        Swal.fire({
                            icon: 'error',
                            title: 'Connection Error',
                            text: 'Failed to update doctor status.'
                        });
                    }
                });
            });

            // Open Stats Panel Drawer on doctor name click
            var statsDrawer = new bootstrap.Offcanvas(document.getElementById('statsPanelDrawer'));
            $(document).on('click', '.btnStats', function () {
                var id = $(this).data('id');
                var docName = $(this).text().trim();
                $('#statsPanelLabel').html('<i class="bi bi-bar-chart-line me-2 text-primary"></i>Stats &amp; History');
                $('#statsPanelBody').html('<div class="text-center py-5 text-muted"><div class="spinner-border spinner-border-sm text-primary mb-2" role="status"></div><p class="small mb-0">Loading stats...</p></div>');
                statsDrawer.show();
                $.get('@Url.Action("StatsPanel")/' + id, function (html) {
                    $('#statsPanelBody').html(html);
                }).fail(function () {
                    $('#statsPanelBody').html('<div class="text-center py-5 text-danger small"><i class="bi bi-exclamation-circle d-block fs-3 mb-2"></i>Failed to load stats.</div>');
                });
            });

            // Delete Doctor Handler
            $(document).on('click', '.btnDelete', function () {
                var id = $(this).data('id');
                Swal.fire({
                    title: 'Are you sure?',
                    text: "You are about to delete this doctor's profile and user account. This action cannot be undone!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc2626',
                    cancelButtonColor: '#64748b',
                    confirmButtonText: 'Yes, delete it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("Delete")/' + id,
                            type: 'POST',
                            data: {
                                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                            },
                            success: function (res) {
                                if (res.success) {
                                    Swal.fire({
                                        icon: 'success',
                                        title: 'Deleted!',
                                        text: res.message,
                                        timer: 1500,
                                        showConfirmButton: false
                                    }).then(function () {
                                        location.reload();
                                    });
                                } else {
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Failed',
                                        text: res.message
                                    });
                                }
                            },
                            error: function () {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'System Error',
                                    text: 'An unexpected error occurred.'
                                });
                            }
                        });
                    }
                });
            });
        });
    </script>
}
