@model Pharma_Script.Models.Appointment
@{
    Layout = "~/Views/Public/Shared/_PublicLayout.cshtml";
    var payment = ViewBag.Payment as Pharma_Script.Models.Payment;
    var paymentSucceeded = payment?.PaymentStatus == "Paid";
}

<section class="pub-section">
    <div class="container text-center" style="max-width:640px;">
        <div class="pub-service-icon mx-auto mb-3" style="width:72px;height:72px;font-size:2rem;">
            <i class="bi bi-check-lg"></i>
        </div>
        <h2 class="pub-heading">Appointment Confirmed</h2>
        <p class="text-muted">Your appointment with <strong>Dr. @Model.DoctorName</strong> has been booked successfully.</p>

        @if (payment != null)
        {
            <div class="alert @(paymentSucceeded ? "alert-success" : "alert-warning") d-flex align-items-center gap-2 text-start mt-3 mb-0">
                <i class="bi @(paymentSucceeded ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") fs-5"></i>
                <div>
                    <div class="fw-bold">@(paymentSucceeded ? "Payment Successful" : $"Payment {payment.PaymentStatus}")</div>
                    <div class="small">₹@payment.Amount.ToString("0.##") paid via @payment.PaymentMethod &middot; Ref: @payment.TransactionReference</div>
                </div>
            </div>
        }

        <div class="pub-service-card text-start mt-4">
            <div class="row g-3">
                <div class="col-6">
                    <div class="small text-muted">Date</div>
                    <div class="fw-semibold">@Model.AppointmentDate.ToString("dd MMM yyyy")</div>
                </div>
                <div class="col-6">
                    <div class="small text-muted">Time</div>
                    <div class="fw-semibold">@Model.StartTime.ToString(@"hh\:mm")</div>
                </div>
                <div class="col-6">
                    <div class="small text-muted">Consultation Type</div>
                    <div class="fw-semibold">@Model.AppointmentType</div>
                </div>
                <div class="col-6">
                    <div class="small text-muted">Status</div>
                    <div class="fw-semibold">@Model.Status</div>
                </div>
            </div>
        </div>

        <a href="/@ViewContext.RouteData.Values["slug"]/my/appointments" class="pub-btn-cta d-inline-block mt-4">View My Appointments</a>
    </div>
</section>
