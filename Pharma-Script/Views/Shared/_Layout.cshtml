@using Pharma_Script.Helpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Script India Healthcare</title>
    
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <!-- Bootstrap Icons CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <!-- SweetAlert2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    
    <!-- Custom modern stylesheet -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @if (User.Identity?.IsAuthenticated == true)
    {
        @Html.AntiForgeryToken()
        <div class="app-container">
            <!-- Sidebar Navigation (SaaS Layout) -->
            @await Html.PartialAsync("_Sidebar")

            <!-- Main Workspace -->
            <div class="main-wrapper">
                <!-- Top sticky Navbar -->
                <header class="top-navbar">
                    <div class="d-flex align-items-center gap-2">
                        <button class="navbar-icon-btn d-lg-none" type="button" id="sidebarToggle" title="Toggle sidebar">
                            <i class="bi bi-list" style="font-size:1.25rem;"></i>
                        </button>
                        <div class="d-flex d-lg-none align-items-center">
                            <a href="@Url.Action("Index", "Dashboard")" class="d-flex align-items-center text-decoration-none">
                                <img src="~/assets/Cloud Doctor Logo.png" alt="Cloud Doctor" style="max-height: 44px; max-width: 160px; object-fit: contain; width: auto;" />
                            </a>
                        </div>
                    </div>

                    <div class="ms-auto d-flex align-items-center gap-2">
                        <!-- Notifications Dropdown -->
                        <div class="dropdown" id="notificationDropdownContainer">
                            <button class="navbar-icon-btn position-relative" type="button" id="notificationDropdown"
                                    data-bs-toggle="dropdown" aria-expanded="false" title="Notifications">
                                <i class="bi bi-bell" style="font-size:1rem;"></i>
                                <span id="notificationBadge"
                                      class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none"
                                      style="font-size:0.62rem; padding:2px 5px; line-height:1;"></span>
                            </button>
                            <div class="dropdown-menu dropdown-menu-end shadow-sm border mt-1 p-0"
                                 aria-labelledby="notificationDropdown"
                                 style="width:300px;max-height:380px;overflow-y:auto;border-radius:var(--radius-lg);">
                                <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                                    <span style="font-size:0.85rem;font-weight:600;">Notifications</span>
                                    <button class="btn btn-link p-0 text-decoration-none"
                                            id="markAllReadBtn"
                                            style="font-size:0.78rem;color:var(--primary);">Mark all read</button>
                                </div>
                                <div id="notificationList" class="p-2">
                                    <div class="text-center py-4" style="font-size:0.82rem;color:var(--text-muted);">No new notifications</div>
                                </div>
                                <div class="px-3 py-2 border-top text-center">
                                    <a href="/Notifications/All" class="text-decoration-none"
                                       style="font-size:0.8rem;font-weight:500;color:var(--primary);">View all</a>
                                </div>
                            </div>
                        </div>

                        <div class="nav-divider"></div>

                        <!-- User Profile -->
                        <div class="dropdown">
                            <div class="navbar-user-dropdown dropdown-toggle" id="userMenuDropdown"
                                 data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="navbar-user-avatar text-uppercase">
                                    @User.GetFullName().Substring(0, Math.Min(2, User.GetFullName().Length))
                                </div>
                                <div class="d-none d-md-block text-start">
                                    <div class="navbar-username">@User.GetFullName()</div>
                                    <div class="navbar-role">@User.GetRoleName()</div>
                                </div>
                            </div>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border mt-1"
                                aria-labelledby="userMenuDropdown"
                                style="border-radius:var(--radius-lg);min-width:160px;">
                                <li>
                                    <a class="dropdown-item py-2"
                                       href="@Url.Action("Logout", "Account")"
                                       style="font-size:0.85rem;font-weight:500;color:var(--danger);">
                                        <i class="bi bi-box-arrow-right me-2"></i>Sign out
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </header>

                <!-- Page Content Area -->
                <main role="main" class="content-area">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <!-- Guest Login View -->
        <main role="main">
            @RenderBody()
        </main>
    }

    <!-- Standard Framework Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <!-- Client-side unobtrusive validations -->
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        $(document).ready(function () {
            // Mobile sidebar toggle handler
            $('#sidebarToggle').on('click', function (e) {
                e.stopPropagation();
                $('#sidebar').toggleClass('show');
                if ($('#sidebar').hasClass('show')) {
                    $('<div class="sidebar-backdrop"></div>').appendTo('body').on('click', function() {
                        $('#sidebar').removeClass('show');
                        $(this).fadeOut(150, function() { $(this).remove(); });
                    });
                } else {
                    $('.sidebar-backdrop').fadeOut(150, function() { $(this).remove(); });
                }
            });
            
            // Close mobile sidebar on clicking outside
            $(document).on('click', function (e) {
                if (!$(e.target).closest('#sidebar, #sidebarToggle').length) {
                    $('#sidebar').removeClass('show');
                    $('.sidebar-backdrop').fadeOut(150, function() { $(this).remove(); });
                }
            });

            // Notifications Logic
            // Icon/color chosen from the notification's title text rather than just its
            // NotificationType, since the backend only distinguishes "Appointment" vs "Reminder"
            // at the type level but titles are specific (New Appointment Request, Appointment
            // Approved/Cancelled, Consultation Completed, etc).
            function notificationIcon(notif) {
                var title = (notif.title || '').toLowerCase();
                if (title.indexOf('cancel') !== -1 || title.indexOf('reject') !== -1) return { icon: 'bi-calendar-x', color: 'text-danger' };
                if (title.indexOf('approved') !== -1) return { icon: 'bi-calendar-check', color: 'text-success' };
                if (title.indexOf('new appointment') !== -1) return { icon: 'bi-calendar-plus', color: 'text-primary' };
                if (title.indexOf('report') !== -1 || title.indexOf('document') !== -1) return { icon: 'bi-file-earmark-medical', color: 'text-info' };
                if (title.indexOf('meeting') !== -1 || title.indexOf('link') !== -1) return { icon: 'bi-camera-video', color: 'text-primary' };
                if (title.indexOf('follow-up') !== -1 || title.indexOf('follow up') !== -1 || notif.notificationType === 'Reminder') return { icon: 'bi-alarm', color: 'text-warning' };
                if (notif.notificationType === 'Appointment') return { icon: 'bi-calendar-check', color: 'text-success' };
                return { icon: 'bi-info-circle', color: 'text-primary' };
            }

            function loadNotifications() {
                $.get('/Notifications/Unread', function (data) {
                    var count = data.length;
                    var badge = $('#notificationBadge');
                    var list = $('#notificationList');

                    if (count > 0) {
                        badge.removeClass('d-none').text(count > 9 ? '9+' : count);
                        list.empty();
                        $.each(data, function (i, notif) {
                            var style = notificationIcon(notif);

                            var item = `
                                <div class="d-flex align-items-start mb-2 p-2 rounded hover-bg-light cursor-pointer notification-item" data-id="${notif.notificationID}">
                                    <i class="bi ${style.icon} fs-4 ${style.color} me-3"></i>
                                    <div>
                                        <div class="fw-semibold small lh-1 mb-1">${notif.title}</div>
                                        <div class="text-muted" style="font-size: 0.75rem;">${notif.message}</div>
                                    </div>
                                </div>
                            `;
                            list.append(item);
                        });
                    } else {
                        badge.addClass('d-none');
                        list.html('<div class="text-center py-4 text-muted small">No new notifications</div>');
                    }
                });
            }

            // Load on page load
            loadNotifications();

            // Mark single as read
            $(document).on('click', '.notification-item', function () {
                var id = $(this).data('id');
                var elem = $(this);
                $.post('/Notifications/MarkAsRead/' + id, function () {
                    elem.slideUp(200, function() {
                        elem.remove();
                        if ($('.notification-item').length === 0) {
                            $('#notificationBadge').addClass('d-none');
                            $('#notificationList').html('<div class="text-center py-4 text-muted small">No new notifications</div>');
                        }
                    });
                });
            });

            // Mark all as read
            $('#markAllReadBtn').on('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                $.post('/Notifications/MarkAllAsRead', function () {
                    $('#notificationBadge').addClass('d-none');
                    $('#notificationList').html('<div class="text-center py-4 text-muted small">No new notifications</div>');
                });
            });
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
