@using Pharma_Script.Helpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Script India Healthcare</title>
    
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <!-- Bootstrap Icons CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <!-- SweetAlert2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    
    <!-- Custom modern stylesheet -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="app-container">
            <!-- Sidebar Navigation (SaaS Layout) -->
            @await Html.PartialAsync("_Sidebar")

            <!-- Main Workspace -->
            <div class="main-wrapper">
                <!-- Top sticky Navbar -->
                <header class="top-navbar">
                    <button class="btn btn-link text-dark d-lg-none p-0 border-0" type="button" id="sidebarToggle">
                        <i class="bi bi-list fs-3"></i>
                    </button>
                    
                    <div class="ms-auto d-flex align-items-center gap-3">
                        <!-- Notification Badge (Mockup UI) -->
                        <button class="btn btn-link text-secondary p-1 position-relative border-0" type="button" title="Notifications">
                            <i class="bi bi-bell fs-5"></i>
                            <span class="position-absolute top-1 start-100 translate-middle p-1 bg-danger border border-light rounded-circle"></span>
                        </button>

                        <div class="vr my-2" style="height: 20px; color: var(--border-color);"></div>

                        <!-- User Profile Info -->
                        <div class="dropdown">
                            <div class="navbar-user-dropdown dropdown-toggle" id="userMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="navbar-user-avatar text-uppercase">
                                    @User.GetFullName().Substring(0, Math.Min(2, User.GetFullName().Length))
                                </div>
                                <div class="d-none d-md-block text-start">
                                    <h6 class="mb-0 fw-semibold text-dark lh-sm" style="font-size: 0.85rem;">@User.GetFullName()</h6>
                                    <small class="text-muted d-block" style="font-size: 0.7rem; margin-top: 1px;">@User.GetRoleName()</small>
                                </div>
                            </div>
                            <ul class="dropdown-menu dropdown-menu-end border border-light shadow-sm mt-2 rounded-3" aria-labelledby="userMenuDropdown">
                                <li>
                                    <a class="dropdown-item py-2 text-danger small fw-medium" href="@Url.Action("Logout", "Account")">
                                        <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </header>

                <!-- Page Content Area -->
                <main role="main" class="content-area">
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <!-- Guest Login View -->
        <main role="main">
            @RenderBody()
        </main>
    }

    <!-- Standard Framework Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <!-- Client-side unobtrusive validations -->
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        $(document).ready(function () {
            // Mobile sidebar toggle handler
            $('#sidebarToggle').on('click', function (e) {
                e.stopPropagation();
                $('#sidebar').toggleClass('show');
            });
            
            // Close mobile sidebar on clicking outside
            $(document).on('click', function (e) {
                if (!$(e.target).closest('#sidebar, #sidebarToggle').length) {
                    $('#sidebar').removeClass('show');
                }
            });
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
