@using Pharma_Script.Helpers
@using Pharma_Script.Repositories.Interfaces
@inject IUnitOfWork Uow

<div class="sidebar-wrapper" id="sidebar">
    <div class="sidebar-header">
        <a href="@Url.Action("Index", "Dashboard")" class="sidebar-logo p-0 border-0" style="display: flex; align-items: center; width: 100%; height: 100%;">
            <img src="~/assets/Cloud Doctor Logo.png" alt="Cloud Doctor" style="max-height: 52px; max-width: 212px; object-fit: contain; width: 100%; height: auto;" />
        </a>
    </div>
    @{
        var _currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        var _currentAction     = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    }
    <ul class="sidebar-menu">
        <li class="@(_currentController == "Dashboard" ? "active" : "")">
            <a href="@Url.Action("Index", "Dashboard")">
                <i class="bi bi-columns-gap"></i>Dashboard
            </a>
        </li>

        @* ── Doctor Navigation ──────────────────────────────────── *@
        @if (User.IsDoctor())
        {
            var _doctorUserId = User.GetUserId();
            var _sidebarDoctor = await Uow.Doctors.GetByUserIdAsync(_doctorUserId);
            var _doctorId = _sidebarDoctor?.DoctorID ?? 0;

            <li class="sidebar-section-label">My Practice</li>

            <li class="@(_currentController == "Appointments" ? "active" : "")">
                <a href="@Url.Action("Index", "Appointments")">
                    <i class="bi bi-calendar2-check"></i>Appointments
                </a>
            </li>

            <li class="@(_currentController == "Patients" ? "active" : "")">
                <a href="@Url.Action("Index", "Patients")">
                    <i class="bi bi-heart-pulse"></i>Patients
                </a>
            </li>

            <li class="@(_currentController == "Consultation" ? "active" : "")">
                <a href="@Url.Action("Index", "Consultation")">
                    <i class="bi bi-clipboard2-pulse"></i>Consultations
                </a>
            </li>

            @if (_doctorId > 0)
            {
                <li class="sidebar-section-label">Schedule</li>

                <li class="@(_currentController == "DoctorAvailability" ? "active" : "")">
                    <a href="@Url.Action("Schedule", "DoctorAvailability", new { doctorId = _doctorId })">
                        <i class="bi bi-clock-history"></i>My Availability
                    </a>
                </li>

                <li class="@(_currentController == "DoctorLeave" ? "active" : "")">
                    <a href="@Url.Action("Index", "DoctorLeave", new { doctorId = _doctorId })">
                        <i class="bi bi-calendar-minus"></i>Manage Leaves
                    </a>
                </li>
            }
        }

        @* ── Platform Owner Navigation ──────────────────────────── *@
        @if (User.IsPlatformOwner())
        {
            <li class="@(_currentController == "Organizations" ? "active" : "")">
                <a href="@Url.Action("Index", "Organizations")">
                    <i class="bi bi-building"></i>Organizations
                </a>
            </li>
        }

        @* ── Org Admin / Platform Owner Navigation ─────────────── *@
        @if (User.IsPlatformOwner() || User.IsOrganizationAdmin())
        {
            <li class="@(_currentController == "Branches" ? "active" : "")">
                <a href="@Url.Action("Index", "Branches")">
                    <i class="bi bi-diagram-3"></i>Branches
                </a>
            </li>
            <li class="@(_currentController == "Departments" ? "active" : "")">
                <a href="@Url.Action("Index", "Departments")">
                    <i class="bi bi-layers"></i>Departments
                </a>
            </li>
            <li class="@(_currentController == "Roles" ? "active" : "")">
                <a href="@Url.Action("Index", "Roles")">
                    <i class="bi bi-shield-check"></i>Roles
                </a>
            </li>
            <li class="@(_currentController == "Users" ? "active" : "")">
                <a href="@Url.Action("Index", "Users")">
                    <i class="bi bi-people"></i>Users
                </a>
            </li>
            <li class="@(_currentController == "Doctors" ? "active" : "")">
                <a href="@Url.Action("Index", "Doctors")">
                    <i class="bi bi-person-badge-fill"></i>Doctors
                </a>
            </li>
            <li class="@(_currentController == "Receptionists" ? "active" : "")">
                <a href="@Url.Action("Index", "Receptionists")">
                    <i class="bi bi-person-workspace"></i>Receptionists
                </a>
            </li>
            <li class="@(_currentController == "Specializations" ? "active" : "")">
                <a href="@Url.Action("Index", "Specializations")">
                    <i class="bi bi-stethoscope"></i>Specializations
                </a>
            </li>
            <li class="@(_currentController == "Patients" ? "active" : "")">
                <a href="@Url.Action("Index", "Patients")">
                    <i class="bi bi-heart-pulse"></i>Patients
                </a>
            </li>
        }

        @* ── Receptionist Navigation ────────────────────────────── *@
        @if (User.IsReceptionist())
        {
            <li class="@(_currentController == "Appointments" ? "active" : "")">
                <a href="@Url.Action("Index", "Appointments")">
                    <i class="bi bi-calendar2-check"></i>Appointments
                </a>
            </li>
            <li class="@(_currentController == "Patients" ? "active" : "")">
                <a href="@Url.Action("Index", "Patients")">
                    <i class="bi bi-heart-pulse"></i>Patients
                </a>
            </li>
        }

        @{
            var websiteControllers = new[] { "WebsiteSettings", "HeroSections", "Services", "ContactMessages" };
            var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
            var isWebsiteSection = websiteControllers.Contains(currentController);
        }
        @if (User.IsOrganizationAdmin())
        {
            <li class="@(isWebsiteSection ? "active" : "")">
                <a href="#websiteSubmenu" data-bs-toggle="collapse" aria-expanded="@(isWebsiteSection ? "true" : "false")" class="d-flex align-items-center justify-content-between">
                    <span><i class="bi bi-globe2"></i>Website</span>
                    <i class="bi bi-chevron-down small"></i>
                </a>
                <div class="collapse @(isWebsiteSection ? "show" : "")" id="websiteSubmenu">
                    <ul class="sidebar-submenu list-unstyled ps-4 mb-0">
                        <li class="@(currentController == "WebsiteSettings" ? "active" : "")">
                            <a href="@Url.Action("Index", "WebsiteSettings")">Website Settings</a>
                        </li>
                        <li class="@(currentController == "HeroSections" ? "active" : "")">
                            <a href="@Url.Action("Index", "HeroSections")">Hero Section</a>
                        </li>
                        <li class="@(currentController == "Services" ? "active" : "")">
                            <a href="@Url.Action("Index", "Services")">Services</a>
                        </li>
                        <li class="@(currentController == "ContactMessages" ? "active" : "")">
                            <a href="@Url.Action("Index", "ContactMessages")">Contact Messages</a>
                        </li>
                        @{
                            var currentOrgId = User.GetOrganizationId();
                            var currentOrg = currentOrgId.HasValue ? await Uow.Organizations.GetByIdAsync(currentOrgId.Value) : null;
                            var currentOrgSlug = currentOrg?.OrganizationSlug;
                        }
                        @if (!string.IsNullOrEmpty(currentOrgSlug))
                        {
                            <li>
                                <a href="/@currentOrgSlug" target="_blank">View Website <i class="bi bi-box-arrow-up-right small"></i></a>
                            </li>
                        }
                    </ul>
                </div>
            </li>
        }
    </ul>
    
    <div class="sidebar-user-section">
        <div class="sidebar-role-badge">
            <i class="bi bi-shield-check"></i>
            <span class="text-truncate">@User.GetRoleName()</span>
        </div>
    </div>
</div>
