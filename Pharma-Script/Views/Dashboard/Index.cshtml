@using Pharma_Script.Helpers
@{
    Layout = "_Layout";
    ViewData["Title"] = "Dashboard";
}

<div class="page-title-box">
    <div>
        <h4 class="page-title">Dashboard Overview</h4>
        <p class="text-muted small mb-0">Monitor platform metrics, manage quick operations, and view clinic schedules.</p>
    </div>
    <div class="text-secondary small fw-medium">
        <i class="bi bi-calendar3 me-1.5 text-primary"></i>@DateTime.Now.ToString("dd MMMM yyyy")
    </div>
</div>

<!-- Stats Grid -->
<div class="row g-4">
    @if (User.IsPlatformOwner())
    {
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-card-info">
                    <p>Organizations</p>
                    <h3>@ViewBag.OrgsCount</h3>
                </div>
                <div class="stat-card-icon icon-blue">
                    <i class="bi bi-building"></i>
                </div>
            </div>
        </div>
    }

    @if (User.IsPlatformOwner() || User.IsOrganizationAdmin())
    {
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-card-info">
                    <p>Branches</p>
                    <h3>@ViewBag.BranchesCount</h3>
                </div>
                <div class="stat-card-icon icon-green">
                    <i class="bi bi-diagram-3"></i>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-card-info">
                    <p>Departments</p>
                    <h3>@ViewBag.DeptsCount</h3>
                </div>
                <div class="stat-card-icon icon-warning">
                    <i class="bi bi-layers"></i>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-card-info">
                    <p>System Users</p>
                    <h3>@ViewBag.UsersCount</h3>
                </div>
                <div class="stat-card-icon icon-danger">
                    <i class="bi bi-people"></i>
                </div>
            </div>
        </div>
    }

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-card-info">
                <p>Specializations</p>
                <h3>@ViewBag.SpecsCount</h3>
            </div>
            <div class="stat-card-icon icon-blue">
                <i class="bi bi-stethoscope"></i>
            </div>
        </div>
    </div>
</div>

<!-- Premium Widgets Grid -->
<div class="row g-4 mt-2">
    <!-- Mock Chart Analytics Placeholder -->
    <div class="col-12 col-lg-8">
        <div class="table-card p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h6 class="fw-bold text-dark mb-0">System Activity Chart</h6>
                <span class="badge bg-light text-muted border py-1.5 px-2.5">Last 30 Days</span>
            </div>
            
            <div style="height: 250px; position: relative;" class="d-flex align-items-end justify-content-between px-3">
                <!-- Bar Chart Grid lines -->
                <div class="position-absolute w-100 h-100 top-0 start-0 d-flex flex-column justify-content-between pointer-events-none" style="z-index: 1;">
                    <div class="border-bottom w-100" style="height: 0; border-color: var(--border-light) !important;"></div>
                    <div class="border-bottom w-100" style="height: 0; border-color: var(--border-light) !important;"></div>
                    <div class="border-bottom w-100" style="height: 0; border-color: var(--border-light) !important;"></div>
                    <div class="border-bottom w-100" style="height: 0; border-color: var(--border-light) !important;"></div>
                </div>
                
                <!-- Mock Bars -->
                <div class="d-flex flex-column align-items-center gap-1" style="width: 8%; z-index: 2;">
                    <div class="bg-primary-subtle w-100 rounded-top" style="height: 120px; transition: height 0.3s;"></div>
                    <span class="text-muted small" style="font-size: 0.7rem;">Wk 1</span>
                </div>
                <div class="d-flex flex-column align-items-center gap-1" style="width: 8%; z-index: 2;">
                    <div class="bg-primary w-100 rounded-top" style="height: 180px;"></div>
                    <span class="text-muted small" style="font-size: 0.7rem;">Wk 2</span>
                </div>
                <div class="d-flex flex-column align-items-center gap-1" style="width: 8%; z-index: 2;">
                    <div class="bg-primary-subtle w-100 rounded-top" style="height: 90px;"></div>
                    <span class="text-muted small" style="font-size: 0.7rem;">Wk 3</span>
                </div>
                <div class="d-flex flex-column align-items-center gap-1" style="width: 8%; z-index: 2;">
                    <div class="bg-primary w-100 rounded-top" style="height: 210px;"></div>
                    <span class="text-muted small" style="font-size: 0.7rem;">Wk 4</span>
                </div>
                <div class="d-flex flex-column align-items-center gap-1" style="width: 8%; z-index: 2;">
                    <div class="bg-primary-subtle w-100 rounded-top" style="height: 150px;"></div>
                    <span class="text-muted small" style="font-size: 0.7rem;">Wk 5</span>
                </div>
            </div>
        </div>

        <!-- Today's Appointments Widget -->
        <div class="table-card p-4 mt-4">
            <h6 class="fw-bold text-dark mb-3">Today's Appointments (Mockup)</h6>
            <div class="table-responsive">
                <table class="table custom-table">
                    <thead>
                        <tr>
                            <th>Patient Name</th>
                            <th>Doctor</th>
                            <th>Time</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="fw-medium">Rahul Sharma</td>
                            <td>Dr. Ananya Goel</td>
                            <td class="text-muted small">10:30 AM</td>
                            <td><span class="badge-active">Confirmed</span></td>
                        </tr>
                        <tr>
                            <td class="fw-medium">Priya Nair</td>
                            <td>Dr. Vikram Seth</td>
                            <td class="text-muted small">11:15 AM</td>
                            <td><span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded px-2 py-1 small">Pending</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Quick Navigation & Recent Activities -->
    <div class="col-12 col-lg-4">
        <div class="table-card p-4 h-100">
            <h6 class="fw-bold text-dark mb-3">Quick Navigation</h6>
            <div class="d-grid gap-2 mb-4">
                @if (User.IsPlatformOwner())
                {
                    <a href="@Url.Action("Index", "Organizations")" class="btn btn-light text-start py-2.5 px-3">
                        <i class="bi bi-building me-2 text-primary"></i>Manage Organizations
                    </a>
                }
                
                @if (User.IsPlatformOwner() || User.IsOrganizationAdmin())
                {
                    <a href="@Url.Action("Index", "Branches")" class="btn btn-light text-start py-2.5 px-3">
                        <i class="bi bi-diagram-3 me-2 text-primary"></i>Manage Branches
                    </a>
                    <a href="@Url.Action("Index", "Departments")" class="btn btn-light text-start py-2.5 px-3">
                        <i class="bi bi-layers me-2 text-primary"></i>Manage Departments
                    </a>
                    <a href="@Url.Action("Index", "Users")" class="btn btn-light text-start py-2.5 px-3">
                        <i class="bi bi-people me-2 text-primary"></i>Manage Users
                    </a>
                }
            </div>

            <h6 class="fw-bold text-dark mb-3">Recent System Activity</h6>
            <div class="timeline" style="border-left: 2px solid var(--border-light); padding-left: 16px; margin-left: 8px;">
                <div class="mb-3 position-relative">
                    <i class="bi bi-circle-fill text-primary position-absolute" style="left: -22px; top: 4px; font-size: 0.65rem; background: #fff; padding: 2px;"></i>
                    <h6 class="mb-0 fw-semibold text-dark" style="font-size: 0.8rem;">Database Initialized</h6>
                    <small class="text-muted d-block" style="font-size: 0.7rem;">Seed logic executed successfully.</small>
                </div>
                <div class="mb-3 position-relative">
                    <i class="bi bi-circle-fill text-success position-absolute" style="left: -22px; top: 4px; font-size: 0.65rem; background: #fff; padding: 2px;"></i>
                    <h6 class="mb-0 fw-semibold text-dark" style="font-size: 0.8rem;">Roles Seeding Completed</h6>
                    <small class="text-muted d-block" style="font-size: 0.7rem;">Added default user groups.</small>
                </div>
            </div>
        </div>
    </div>
</div>
