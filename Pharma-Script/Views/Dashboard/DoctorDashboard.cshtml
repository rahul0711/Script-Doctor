@using Pharma_Script.Helpers
@using Pharma_Script.Models
@{
    Layout = "_Layout";
    ViewData["Title"] = "Doctor Dashboard";
    var doctor = ViewBag.Doctor as Doctor;
    var todayAppts = ViewBag.TodayAppointments as List<Appointment> ?? new List<Appointment>();
    var today = DateTime.Now.ToString("dd MMMM yyyy");
    var dayName = DateTime.Now.ToString("dddd");
}

<div class="page-title-box">
    <div>
        <h4 class="page-title">
            Good @(DateTime.Now.Hour < 12 ? "Morning" : DateTime.Now.Hour < 17 ? "Afternoon" : "Evening"),
            Dr. @(doctor?.FirstName ?? User.GetFullName()) 👋
        </h4>
        <p class="text-muted small mb-0">Here's your practice overview for today — @dayName, @today</p>
    </div>
    <a href="@Url.Action("Index", "Appointments")" class="btn btn-primary btn-sm px-3">
        <i class="bi bi-calendar2-check me-1"></i> View All Appointments
    </a>
</div>

@if (ViewBag.DoctorError != null)
{
    <div class="alert alert-warning">@ViewBag.DoctorError</div>
}
else
{
    <!-- ── Stat Cards ──────────────────────────────────────────────── -->
    <div class="row g-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-card-info">
                    <p>Today's Appointments</p>
                    <h3>@ViewBag.TodayCount</h3>
                </div>
                <div class="stat-card-icon icon-blue">
                    <i class="bi bi-calendar-check"></i>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-card-info">
                    <p>Pending Approvals</p>
                    <h3>@ViewBag.PendingCount</h3>
                </div>
                <div class="stat-card-icon icon-warning">
                    <i class="bi bi-hourglass-split"></i>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-card-info">
                    <p>Upcoming (Next 7 Days)</p>
                    <h3>@ViewBag.UpcomingCount</h3>
                </div>
                <div class="stat-card-icon icon-green">
                    <i class="bi bi-calendar-week"></i>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stat-card">
                <div class="stat-card-info">
                    <p>Completed Consultations</p>
                    <h3>@ViewBag.CompletedCount</h3>
                </div>
                <div class="stat-card-icon icon-danger">
                    <i class="bi bi-patch-check"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Main Content Row ───────────────────────────────────────── -->
    <div class="row g-4 mt-2">

        <!-- Today's Appointment List -->
        <div class="col-12 col-lg-8">
            <div class="table-card p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h6 class="fw-bold text-dark mb-0">
                        <i class="bi bi-calendar-day text-primary me-2"></i>Today's Schedule
                    </h6>
                    <a href="@Url.Action("Index", "Appointments")" class="btn btn-sm btn-light border text-muted">
                        View All <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>

                @if (!todayAppts.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-calendar-x" style="font-size: 2.5rem; opacity: 0.3;"></i>
                        <p class="mt-3 mb-0 fw-medium">No appointments scheduled for today</p>
                        <small>Enjoy your free day!</small>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table custom-table">
                            <thead>
                                <tr>
                                    <th>Patient</th>
                                    <th>Time</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var appt in todayAppts.OrderBy(a => a.StartTime))
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="avatar-sm rounded-circle bg-primary-subtle d-flex align-items-center justify-content-center"
                                                     style="width: 34px; height: 34px; min-width: 34px;">
                                                    <i class="bi bi-person-fill text-primary" style="font-size: 0.85rem;"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-medium text-dark" style="font-size: 0.875rem;">
                                                        @(appt.PatientName ?? "Patient #" + appt.PatientID)
                                                    </div>
                                                    @if (appt.PriorityConsultation)
                                                    {
                                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle" style="font-size: 0.65rem;">Priority</span>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-muted small">
                                            @appt.StartTime.ToString(@"hh\:mm") – @appt.EndTime.ToString(@"hh\:mm")
                                        </td>
                                        <td>
                                            @{
                                                var typeIcon = appt.AppointmentType switch
                                                {
                                                    "Video" => "bi-camera-video text-info",
                                                    "Voice" => "bi-telephone text-success",
                                                    _ => "bi-hospital text-primary"
                                                };
                                            }
                                            <span class="text-muted small">
                                                <i class="bi @typeIcon me-1"></i>@appt.AppointmentType
                                            </span>
                                        </td>
                                        <td>
                                            @{
                                                var (badgeClass, badgeText) = appt.Status switch
                                                {
                                                    "Approved"    => ("badge-active", "Approved"),
                                                    "Pending"     => ("badge bg-warning-subtle text-warning border border-warning-subtle rounded px-2 py-1 small", "Pending"),
                                                    "Completed"   => ("badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded px-2 py-1 small", "Completed"),
                                                    "Cancelled"   => ("badge bg-danger-subtle text-danger border border-danger-subtle rounded px-2 py-1 small", "Cancelled"),
                                                    _             => ("badge bg-light text-muted border rounded px-2 py-1 small", appt.Status)
                                                };
                                            }
                                            <span class="@badgeClass">@badgeText</span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Details", "Appointments", new { id = appt.AppointmentID })"
                                               class="btn btn-sm btn-light border px-2 py-1">
                                                <i class="bi bi-eye" style="font-size: 0.75rem;"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Quick Actions & Doctor Profile -->
        <div class="col-12 col-lg-4">

            <!-- Doctor Profile Card -->
            @if (doctor != null)
            {
                <div class="table-card p-4 mb-4">
                    <h6 class="fw-bold text-dark mb-3">My Profile</h6>
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="rounded-circle bg-primary-subtle d-flex align-items-center justify-content-center"
                             style="width: 52px; height: 52px; min-width: 52px;">
                            <i class="bi bi-person-circle text-primary" style="font-size: 1.6rem;"></i>
                        </div>
                        <div>
                            <div class="fw-semibold text-dark">Dr. @doctor.FirstName @doctor.LastName</div>
                            <small class="text-muted">
                                @(doctor.SpecializationNames.Any() ? string.Join(", ", doctor.SpecializationNames) : "General")
                            </small>
                        </div>
                    </div>
                    <div class="d-flex flex-column gap-1" style="font-size: 0.8rem;">
                        @if (!string.IsNullOrEmpty(doctor.DepartmentName))
                        {
                            <div class="text-muted">
                                <i class="bi bi-layers me-2 text-primary"></i>@doctor.DepartmentName
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(doctor.BranchName))
                        {
                            <div class="text-muted">
                                <i class="bi bi-geo-alt me-2 text-primary"></i>@doctor.BranchName
                            </div>
                        }
                        <div class="text-muted">
                            <i class="bi bi-award me-2 text-primary"></i>@doctor.Qualification — @doctor.ExperienceYears yrs exp.
                        </div>
                    </div>
                </div>
            }

            <!-- Quick Navigation -->
            <div class="table-card p-4">
                <h6 class="fw-bold text-dark mb-3">Quick Actions</h6>
                <div class="d-grid gap-2">
                    <a href="@Url.Action("Index", "Appointments")" class="btn btn-light text-start py-2 px-3">
                        <i class="bi bi-calendar2-check me-2 text-primary"></i>My Appointments
                    </a>
                    <a href="@Url.Action("Index", "Patients")" class="btn btn-light text-start py-2 px-3">
                        <i class="bi bi-heart-pulse me-2 text-danger"></i>My Patients
                    </a>
                    @if (doctor != null)
                    {
                        <a href="@Url.Action("Schedule", "DoctorAvailability", new { doctorId = doctor.DoctorID })"
                           class="btn btn-light text-start py-2 px-3">
                            <i class="bi bi-clock-history me-2 text-success"></i>My Availability
                        </a>
                        <a href="@Url.Action("Index", "DoctorLeave", new { doctorId = doctor.DoctorID })"
                           class="btn btn-light text-start py-2 px-3">
                            <i class="bi bi-calendar-minus me-2 text-warning"></i>Manage Leaves
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
}
