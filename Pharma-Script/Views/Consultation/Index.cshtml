@model IEnumerable<Pharma_Script.Models.Appointment>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Consultation Workspace";
}

<div class="page-title-box d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h4 class="page-title mb-1">Consultation Workspace</h4>
        <p class="text-muted small mb-0">Conduct medical checkups, write prescriptions, and view diagnostic history.</p>
    </div>
</div>

<div class="table-card mb-4">
    <div class="table-card-header d-flex align-items-center bg-white">
        <h5 class="table-card-title mb-0">
            <i class="bi bi-clipboard2-pulse text-primary me-2"></i>My Consultations
        </h5>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table custom-table align-middle">
                <thead>
                    <tr>
                        <th style="width: 150px;">Date &amp; Time</th>
                        <th>Patient Name</th>
                        <th style="width: 130px;">Channel</th>
                        <th class="text-center" style="width: 120px;">Urgency</th>
                        <th class="text-center" style="width: 120px;">Status</th>
                        <th class="text-end" style="width: 250px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appt in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold text-dark">@appt.AppointmentDate.ToString("dd-MMM-yyyy")</div>
                                <div class="text-muted small" style="font-size:0.75rem;">@DateTime.Today.Add(appt.StartTime).ToString("hh:mm tt")</div>
                            </td>
                            <td>
                                <div class="fw-semibold text-dark">@appt.PatientName</div>
                                <div class="text-muted small" style="font-size:0.75rem;">ID: PAT-@appt.PatientID</div>
                            </td>
                            <td>
                                @if (appt.AppointmentType == "Video")
                                {
                                    <span class="text-success fw-medium"><i class="bi bi-camera-video me-1.5"></i>Video</span>
                                }
                                else if (appt.AppointmentType == "Voice")
                                {
                                    <span class="text-info fw-medium"><i class="bi bi-telephone me-1.5"></i>Voice</span>
                                }
                                else
                                {
                                    <span class="text-primary fw-medium"><i class="bi bi-hospital me-1.5"></i>Clinic</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (appt.PriorityConsultation)
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-1.5 rounded-pill border-0 shadow-none">Priority</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-secondary px-3 py-1.5 rounded-pill border-0 shadow-none">Normal</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (appt.Status == "Approved")
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success px-3 py-1.5 rounded-pill fw-semibold border-0">Ready</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary px-3 py-1.5 rounded-pill border-0">Completed</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    @if (appt.Status == "Approved")
                                    {
                                        <a href="@Url.Action("Workspace", "Consultation", new { id = appt.AppointmentID })" class="btn btn-sm btn-success fw-medium px-3 shadow-sm border-0" style="border-radius: 6px;">
                                            <i class="bi bi-stethoscope me-1.5"></i>Open Workspace
                                        </a>
                                    }
                                    else if (appt.Status == "Completed")
                                    {
                                        <a href="@Url.Action("PrintPrescription", "Consultation", new { id = appt.AppointmentID })" target="_blank" class="btn btn-sm btn-light text-primary px-3 fw-medium border-0 shadow-sm" style="background:var(--primary-bg); border-radius: 6px;">
                                            <i class="bi bi-printer me-1.5"></i>Print Rx
                                        </a>
                                    }
                                    <a href="@Url.Action("Details", "Appointments", new { id = appt.AppointmentID })" class="btn btn-sm btn-light text-secondary px-3 shadow-sm border-0" style="border-radius: 6px;">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="text-muted mb-3"><i class="bi bi-calendar-check" style="font-size: 3rem;"></i></div>
            <h6 class="text-dark fw-semibold">No pending consultations.</h6>
            <p class="text-muted small mb-0">You're all caught up for now!</p>
        </div>
    }
</div>
