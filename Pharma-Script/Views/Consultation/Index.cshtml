@model IEnumerable<Pharma_Script.Models.Appointment>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Consultation Workspace";
}

<div class="page-title-box">
    <div>
        <h4 class="page-title">Consultation Workspace</h4>
        <p class="text-muted small mb-0 font-medium">Conduct medical checkups, write prescriptions, and view diagnostic history.</p>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <h5 class="card-title text-dark border-bottom pb-3 mb-3">
            <i class="bi bi-clipboard2-pulse text-primary me-2"></i>My Consultations
        </h5>

        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table custom-table align-middle">
                    <thead>
                        <tr>
                            <th>Date &amp; Time</th>
                            <th>Patient Name</th>
                            <th>Channel</th>
                            <th>Urgancy</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appt in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold text-dark">@appt.AppointmentDate.ToString("dd-MMM-yyyy")</div>
                                    <small class="text-secondary">@DateTime.Today.Add(appt.StartTime).ToString("hh:mm tt")</small>
                                </td>
                                <td>
                                    <div class="fw-semibold text-dark">@appt.PatientName</div>
                                    <small class="text-muted">ID: PAT-@appt.PatientID</small>
                                </td>
                                <td>
                                    @if (appt.AppointmentType == "Video")
                                    {
                                        <span class="text-info"><i class="bi bi-camera-video me-1"></i>Video</span>
                                    }
                                    else if (appt.AppointmentType == "Voice")
                                    {
                                        <span class="text-warning"><i class="bi bi-telephone me-1"></i>Voice</span>
                                    }
                                    else
                                    {
                                        <span class="text-primary"><i class="bi bi-hospital me-1"></i>Clinic</span>
                                    }
                                </td>
                                <td>
                                    @if (appt.PriorityConsultation)
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger px-2.5 py-1 rounded-pill">Priority</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-secondary px-2.5 py-1 rounded-pill">Normal</span>
                                    }
                                </td>
                                <td>
                                    @if (appt.Status == "Approved")
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success px-2.5 py-1.5 rounded-pill fw-semibold">Ready</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary px-2.5 py-1.5 rounded-pill">Completed</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        @if (appt.Status == "Approved")
                                        {
                                            <a href="@Url.Action("Workspace", "Consultation", new { id = appt.AppointmentID })" class="btn btn-sm btn-success fw-medium">
                                                <i class="bi bi-stethoscope me-1"></i>Open Workspace
                                            </a>
                                        }
                                        else if (appt.Status == "Completed")
                                        {
                                            <a href="@Url.Action("PrintPrescription", "Consultation", new { id = appt.AppointmentID })" target="_blank" class="btn btn-sm btn-outline-primary fw-medium">
                                                <i class="bi bi-printer me-1"></i>Print Rx
                                            </a>
                                        }
                                        <a href="@Url.Action("Details", "Appointments", new { id = appt.AppointmentID })" class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-eye"></i> Details
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-clipboard-x fs-1 d-block mb-3 text-secondary"></i>
                <h6 class="fw-semibold text-secondary">No active consultations found.</h6>
                <p class="small mb-0">Consultation listings will appear here once appointments are approved or completed.</p>
            </div>
        }
    </div>
</div>
