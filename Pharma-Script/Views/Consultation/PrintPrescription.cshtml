@model dynamic
@{
    Layout = null;
    var appt = (Pharma_Script.Models.Appointment)ViewBag.Appointment;
    var prescription = (Pharma_Script.Models.Prescription)ViewBag.Prescription;
    var medicines = (IEnumerable<Pharma_Script.Models.PrescriptionMedicine>)ViewBag.Medicines;
    var doctor = (Pharma_Script.Models.Doctor)ViewBag.Doctor;
    var patient = (Pharma_Script.Models.Patient)ViewBag.Patient;
    var notes = (Pharma_Script.Models.DoctorNote?)ViewBag.Notes;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prescription — @prescription.PrescriptionNumber</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    
    <style>
        body {
            background-color: #fff;
            color: #333;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: 14px;
            padding: 20px;
        }
        .prescription-wrap {
            max-width: 800px;
            margin: 0 auto;
            border: 1px solid #dee2e6;
            padding: 40px;
            background: #fff;
            box-shadow: 0 0 10px rgba(0,0,0,0.02);
            border-radius: 8px;
        }
        .letterhead-header {
            border-bottom: 3px solid var(--bs-primary);
            padding-bottom: 20px;
            margin-bottom: 35px;
        }
        .letterhead-logo {
            font-size: 24px;
            font-weight: 800;
            color: var(--bs-primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .rx-symbol {
            font-size: 28px;
            font-weight: bold;
            color: var(--bs-primary);
            font-family: 'Times New Roman', Times, serif;
        }
        .meta-box {
            background-color: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 6px;
            padding: 15px 20px;
            margin-bottom: 35px;
        }
        .meta-title {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #6c757d;
            margin-bottom: 2px;
            font-weight: 600;
        }
        .meta-val {
            font-weight: 600;
            color: #212529;
        }
        .section-title {
            font-weight: 700;
            font-size: 15px;
            color: #495057;
            border-bottom: 1px solid #e9ecef;
            padding-bottom: 6px;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        /* Print Styles */
        @@media print {
            body {
                padding: 0;
                background-color: #fff;
            }
            .prescription-wrap {
                border: none;
                box-shadow: none;
                padding: 0;
            }
            .no-print {
                display: none !important;
            }
        }
    </style>
</head>
<body>

<div class="container my-3 no-print text-center">
    <button class="btn btn-primary px-4 py-2 fw-bold" onclick="window.print()"><i class="bi bi-printer me-2"></i>Print Prescription</button>
</div>

<div class="prescription-wrap">
    <!-- 1. Header (Letterhead) -->
    <div class="letterhead-header d-flex justify-content-between align-items-start">
        <div>
            <div class="letterhead-logo mb-1"><i class="bi bi-heartpulse-fill"></i> @appt.OrganizationName</div>
            <p class="text-secondary small mb-0">Branch: @(appt.BranchName ?? "Global main node")</p>
        </div>
        <div class="text-end">
            <h5 class="fw-bold mb-0 text-dark">Dr. @doctor.FirstName @doctor.LastName</h5>
            <p class="text-secondary small mb-1">@doctor.Qualification</p>
            <p class="text-muted small mb-0" style="font-size: 0.75rem;">Reg No: @doctor.MedicalRegistrationNumber</p>
        </div>
    </div>

    <!-- 2. Patient metadata block -->
    <div class="meta-box">
        <div class="row g-3">
            <div class="col-6 col-md-3">
                <div class="meta-title">Patient Name</div>
                <div class="meta-val">@patient.FirstName @patient.LastName</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="meta-title">Age / Gender</div>
                <div class="meta-val">@(DateTime.Today.Year - patient.DateOfBirth.Year) Yrs / @patient.Gender</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="meta-title">Prescription No.</div>
                <div class="meta-val">@prescription.PrescriptionNumber</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="meta-title">Date</div>
                <div class="meta-val">@appt.AppointmentDate.ToString("dd-MMM-yyyy")</div>
            </div>
        </div>
    </div>

    <!-- 3. Diagnosis -->
    @if (notes != null && !string.IsNullOrEmpty(notes.Diagnosis))
    {
        <div class="mb-4">
            <div class="section-title">Diagnosis</div>
            <div class="fw-semibold text-dark">@notes.Diagnosis</div>
        </div>
    }

    <!-- 4. Medicines list -->
    <div class="mb-5">
        <div class="d-flex align-items-center gap-2 mb-3">
            <span class="rx-symbol">R<sub>x</sub></span>
            <div class="section-title flex-grow-1 mb-0 border-0">Medicines (Rx)</div>
        </div>

        <table class="table table-bordered table-sm align-middle">
            <thead class="table-light small">
                <tr>
                    <th style="width: 5%;">#</th>
                    <th style="width: 35%;">Medicine Details</th>
                    <th style="width: 25%;">Frequency</th>
                    <th style="width: 15%;">Timing</th>
                    <th style="width: 10%;" class="text-center">Duration</th>
                    <th style="width: 10%;" class="text-center">Qty</th>
                </tr>
            </thead>
            <tbody class="small">
                @if (medicines != null && medicines.Any())
                {
                    int idx = 1;
                    foreach (var med in medicines)
                    {
                        var freq = new List<string>();
                        if (med.Morning) freq.Add("Morning");
                        if (med.Afternoon) freq.Add("Afternoon");
                        if (med.Night) freq.Add("Night");
                        var freqStr = freq.Any() ? string.Join(" - ", freq) + $" ({med.Dosage ?? "1-0-1"})" : med.Dosage ?? "1-0-1";

                        var timing = med.BeforeFood ? "Before Food" : "After Food";

                        <tr>
                            <td>@(idx++)</td>
                            <td>
                                <div class="fw-bold text-dark">@med.MedicineName</div>
                                @if (!string.IsNullOrEmpty(med.Strength))
                                {
                                    <span class="badge bg-light text-secondary rounded">Strength: @med.Strength</span>
                                }
                                @if (!string.IsNullOrEmpty(med.Remarks))
                                {
                                    <div class="text-muted small mt-0.5">Note: @med.Remarks</div>
                                }
                            </td>
                            <td>@freqStr</td>
                            <td>@timing</td>
                            <td class="text-center">@med.DurationDays Days</td>
                            <td class="text-center">@(med.Quantity?.ToString() ?? "-")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-3 text-secondary">No medicines prescribed.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- 5. Instructions and follow-up -->
    <div class="row g-4 mb-5 text-dark">
        <div class="col-12 col-md-8">
            @if (!string.IsNullOrEmpty(prescription.GeneralInstructions))
            {
                <div class="section-title">General Instructions</div>
                <p class="small text-secondary" style="white-space: pre-line;">@prescription.GeneralInstructions</p>
            }
        </div>
        
        <div class="col-12 col-md-4">
            @if (prescription.NextVisitDate.HasValue)
            {
                <div class="section-title">Follow-Up Visit</div>
                <div class="fw-bold text-dark"><i class="bi bi-calendar-event text-primary me-2"></i>@prescription.NextVisitDate.Value.ToString("dd-MMM-yyyy")</div>
            }
        </div>
    </div>

    <!-- 6. Footer (Doctor Sign) -->
    <div class="mt-5 pt-5 border-top d-flex justify-content-between align-items-end text-dark">
        <div class="small text-secondary">
            Generated by Script India Healthcare portal.
        </div>
        <div class="text-center" style="width: 180px;">
            <div style="height: 50px;" class="border-bottom mb-2"></div>
            <div class="small fw-bold text-dark">Dr. @doctor.FirstName @doctor.LastName</div>
            <div class="small text-secondary">Authorized Signature</div>
        </div>
    </div>
</div>

</body>
</html>
