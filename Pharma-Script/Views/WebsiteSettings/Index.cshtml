@model Pharma_Script.Models.CMSSetting
@{
    Layout = "_Layout";
    ViewData["Title"] = "Website Settings";
}

<div class="page-title-box d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h4 class="page-title mb-1">Website Settings</h4>
        <p class="text-muted small mb-0">Configure your public clinic website's identity, branding, and contact details.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a asp-controller="Doctors" asp-action="Index" class="btn btn-light btn-sm text-secondary bg-white border border-light shadow-sm px-3" style="border-radius: 8px;">
            <i class="bi bi-person-badge me-1.5 text-primary"></i>Manage Doctors
        </a>
        @if (!string.IsNullOrEmpty(ViewBag.OrganizationSlug as string))
        {
            <a href="/@ViewBag.OrganizationSlug" target="_blank" rel="noopener" class="btn btn-primary btn-sm px-3 shadow-sm" style="border-radius: 8px;">
                <i class="bi bi-box-arrow-up-right me-1.5"></i>View Live Website
            </a>
        }
    </div>
</div>

<div class="premium-settings-card">
    <ul class="nav nav-tabs settings-nav-tabs" id="settingsTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-general" type="button">
                <i class="bi bi-gear"></i>General
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-branding" type="button">
                <i class="bi bi-palette"></i>Branding
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-about" type="button">
                <i class="bi bi-info-circle"></i>About Us
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-contact" type="button">
                <i class="bi bi-telephone"></i>Contact Details
            </button>
        </li>
        <!-- <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-footer" type="button">
                <i class="bi bi-layout-text-window"></i>Footer
            </button>
        </li> -->
    </ul>

    <div class="tab-content p-4">
        <!-- General -->
        <div class="tab-pane fade show active" id="tab-general">
            <form class="cms-settings-form text-start" asp-action="SaveGeneral" method="post">
                @Html.AntiForgeryToken()
                <div class="cms-settings-section">
                    <h6 class="cms-settings-section-title"><i class="bi bi-gear text-primary"></i>General Settings</h6>
                    <div class="row g-3">
                        <div class="col-12 col-md-8 col-lg-6">
                            <label class="form-label small fw-semibold text-secondary mb-1">Website Title</label>
                            <input name="WebsiteTitle" class="form-control bg-light border-light" value="@Model.WebsiteTitle" placeholder="e.g. Apollo Hospitals" required />
                        </div>
                    </div>
                </div>
                <div class="mt-4 pt-3 border-top border-light text-start">
                    <button type="submit" class="btn btn-primary px-4 shadow-sm" style="border-radius: 8px;">Save General Settings</button>
                </div>
            </form>
        </div>

        <!-- Branding -->
        <div class="tab-pane fade" id="tab-branding">
            <form class="cms-settings-form text-start" asp-action="SaveBranding" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="cms-settings-section">
                    <h6 class="cms-settings-section-title"><i class="bi bi-palette text-primary"></i>Branding &amp; Colors</h6>
                    <div class="row g-4">
                        <div class="col-12 col-md-6 col-lg-5">
                            <label class="form-label small fw-semibold text-secondary mb-1.5">Primary Color (SaaS Accent)</label>
                            <div class="color-picker-wrapper">
                                <input type="color" id="primaryColorPicker" value="@(Model.PrimaryColor ?? "#2563EB")">
                                <input name="PrimaryColor" id="primaryColorText" class="form-control" value="@(Model.PrimaryColor ?? "#2563EB")" placeholder="#2563EB" pattern="^#([0-9a-fA-F]{6})$" />
                            </div>
                            <span class="form-text small text-muted">Primary theme color for header highlights, links, and main buttons.</span>
                        </div>
                        <div class="col-12 col-md-6 col-lg-5">
                            <label class="form-label small fw-semibold text-secondary mb-1.5">Secondary Color</label>
                            <div class="color-picker-wrapper">
                                <input type="color" id="secondaryColorPicker" value="@(Model.SecondaryColor ?? "#059669")">
                                <input name="SecondaryColor" id="secondaryColorText" class="form-control" value="@(Model.SecondaryColor ?? "#059669")" placeholder="#059669" pattern="^#([0-9a-fA-F]{6})$" />
                            </div>
                            <span class="form-text small text-muted">Accent styling color for secondary elements and highlights.</span>
                        </div>
                        <div class="col-12 col-md-6 col-lg-5">
                            <label class="form-label small fw-semibold text-secondary mb-1">Website Logo</label>
                            @if (!string.IsNullOrEmpty(Model.WebsiteLogo))
                            {
                                <div class="mb-3 p-2 bg-light rounded d-inline-block border"><img src="@Model.WebsiteLogo" alt="Current logo" style="max-height:48px; object-fit: contain;" /></div>
                            }
                            <input type="file" name="Logo" class="form-control bg-light border-light" accept=".jpg,.jpeg,.png,.webp" />
                            <span class="form-text small text-muted">Recommended dimension: Horizontal aspect ratio. JPG, PNG, or WEBP (Max 2MB).</span>
                        </div>
                        <div class="col-12 col-md-6 col-lg-5">
                            <label class="form-label small fw-semibold text-secondary mb-1">Favicon</label>
                            @if (!string.IsNullOrEmpty(Model.Favicon))
                            {
                                <div class="mb-3 p-2 bg-light rounded d-inline-block border"><img src="@Model.Favicon" alt="Current favicon" style="height:32px;" /></div>
                            }
                            <input type="file" name="Favicon" class="form-control bg-light border-light" accept=".png,.ico" />
                            <span class="form-text small text-muted">Browser icon. PNG or ICO (Max 512KB).</span>
                        </div>
                    </div>
                </div>
                <div class="mt-4 pt-3 border-top border-light text-start">
                    <button type="submit" class="btn btn-primary px-4 shadow-sm" style="border-radius: 8px;">Save Branding</button>
                </div>
            </form>
        </div>

        <!-- About -->
        <div class="tab-pane fade" id="tab-about">
            <form class="cms-settings-form text-start" asp-action="SaveAbout" method="post">
                @Html.AntiForgeryToken()
                <div class="cms-settings-section">
                    <h6 class="cms-settings-section-title"><i class="bi bi-info-circle text-primary"></i>About Section Details</h6>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-semibold text-secondary mb-1">About Us Statement</label>
                            <textarea name="AboutUs" class="form-control bg-light border-light" rows="5" placeholder="Tell users about your medical practices, services, and commitment.">@Model.AboutUs</textarea>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label small fw-semibold text-secondary mb-1">Mission Statement</label>
                            <textarea name="Mission" class="form-control bg-light border-light" rows="4" placeholder="Your clinical mission...">@Model.Mission</textarea>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label small fw-semibold text-secondary mb-1">Vision Statement</label>
                            <textarea name="Vision" class="form-control bg-light border-light" rows="4" placeholder="Your clinical vision...">@Model.Vision</textarea>
                        </div>
                    </div>
                </div>
                <div class="mt-4 pt-3 border-top border-light text-start">
                    <button type="submit" class="btn btn-primary px-4 shadow-sm" style="border-radius: 8px;">Save About Section</button>
                </div>
            </form>
        </div>

        <!-- Contact -->
        <div class="tab-pane fade" id="tab-contact">
            <form class="cms-settings-form text-start" asp-action="SaveContact" method="post">
                @Html.AntiForgeryToken()
                <div class="cms-settings-section">
                    <h6 class="cms-settings-section-title"><i class="bi bi-telephone text-primary"></i>Contact Info &amp; Locations</h6>
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label small fw-semibold text-secondary mb-1">Contact Email</label>
                            <input name="ContactEmail" type="email" class="form-control bg-light border-light" value="@Model.ContactEmail" required />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label small fw-semibold text-secondary mb-1">Contact Phone</label>
                            <input name="ContactPhone" class="form-control bg-light border-light" value="@Model.ContactPhone" required />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label small fw-semibold text-secondary mb-1">Emergency Hotline</label>
                            <input name="EmergencyPhone" class="form-control bg-light border-light" value="@Model.EmergencyPhone" />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold text-secondary mb-1">Clinic Address</label>
                            <textarea name="Address" class="form-control bg-light border-light" rows="2" required>@Model.Address</textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold text-secondary mb-1">Google Maps Embed URL</label>
                            <input name="GoogleMapEmbed" class="form-control bg-light border-light" value="@Model.GoogleMapEmbed" placeholder="Paste only the src URL from the iframe embed link" />
                            <span class="form-text small text-muted">Only a valid maps URL is allowed to prevent layouts from breaking.</span>
                        </div>
                    </div>
                </div>
                <div class="mt-4 pt-3 border-top border-light text-start">
                    <button type="submit" class="btn btn-primary px-4 shadow-sm" style="border-radius: 8px;">Save Contact Info</button>
                </div>
            </form>
        </div>

        <!-- Footer -->
        <!-- <div class="tab-pane fade" id="tab-footer">
            <form class="cms-settings-form text-start" asp-action="SaveFooter" method="post">
                @Html.AntiForgeryToken()
                <div class="cms-settings-section">
                    <h6 class="cms-settings-section-title"><i class="bi bi-layout-text-window text-primary"></i>Footer Layout Text</h6>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-semibold text-secondary mb-1">Footer Copyright Text / Disclaimer</label>
                            <textarea name="FooterText" class="form-control bg-light border-light" rows="3">@Model.FooterText</textarea>
                        </div>
                    </div>
                </div>
                <div class="mt-4 pt-3 border-top border-light text-start">
                    <button type="submit" class="btn btn-primary px-4 shadow-sm" style="border-radius: 8px;">Save Footer</button>
                </div>
            </form>
        </div> -->
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Keep color text + swatch in sync
            $('#primaryColorPicker').on('input', function () { $('#primaryColorText').val($(this).val().toUpperCase()); });
            $('#secondaryColorPicker').on('input', function () { $('#secondaryColorText').val($(this).val().toUpperCase()); });
            $('#primaryColorText').on('input', function () { if (/^#([0-9a-fA-F]{6})$/.test($(this).val())) $('#primaryColorPicker').val($(this).val()); });
            $('#secondaryColorText').on('input', function () { if (/^#([0-9a-fA-F]{6})$/.test($(this).val())) $('#secondaryColorPicker').val($(this).val()); });

            $('.cms-settings-form').on('submit', function (e) {
                e.preventDefault();
                var form = $(this);
                var btnSubmit = form.find('button[type="submit"]');
                var originalHtml = btnSubmit.html();
                btnSubmit.html('<span class="spinner-border spinner-border-sm me-1.5"></span>Saving...').prop('disabled', true);

                $.ajax({
                    url: form.attr('action'),
                    type: 'POST',
                    data: new FormData(form[0]),
                    processData: false,
                    contentType: false,
                    success: function (res) {
                        btnSubmit.html(originalHtml).prop('disabled', false);
                        if (res.success) {
                            Swal.fire({ icon: 'success', title: 'Saved', text: res.message, timer: 1500, showConfirmButton: false })
                                .then(function () { location.reload(); });
                        } else {
                            var errorMsg = res.message;
                            if (res.errors && res.errors.length > 0) errorMsg += '\n' + res.errors.join('\n');
                            Swal.fire({ icon: 'error', title: 'Validation Error', text: errorMsg });
                        }
                    },
                    error: function () {
                        btnSubmit.html(originalHtml).prop('disabled', false);
                        Swal.fire({ icon: 'error', title: 'System Error', text: 'An unexpected system error occurred.' });
                    }
                });
            });
        });
    </script>
}
