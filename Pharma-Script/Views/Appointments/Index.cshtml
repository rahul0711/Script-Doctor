@model IEnumerable<Pharma_Script.Models.Appointment>
@using Pharma_Script.Helpers
@{
    Layout = "_Layout";
    ViewData["Title"] = "Appointments";
}

<div class="page-title-box">
    <div>
        <h4 class="page-title">Appointment Registry</h4>
        <p class="text-muted small mb-0 font-medium">Browse, query, and monitor scheduled clinical consultations.</p>
    </div>
    <div>
        @if (User.IsInRole("Patient") || User.IsInRole("Organization Admin") || User.IsInRole("Receptionist"))
        {
            <a href="@Url.Action("Book", "Appointments")" class="btn btn-primary fw-medium px-3.5 py-2">
                <i class="bi bi-calendar-plus me-1.5"></i>Book Appointment
            </a>
        }
    </div>
</div>

<!-- Filters Panel -->
<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-4">
        <form method="get" action="@Url.Action("Index")" class="row g-3">
            <div class="col-12 col-md-3">
                <label class="form-label small fw-semibold text-secondary">Search</label>
                <input type="text" name="searchTerm" class="form-control" placeholder="Search patient, symptoms..." value="@ViewBag.SearchTerm" />
            </div>

            @if (User.IsPlatformOwner() || User.IsInRole("Organization Admin") || User.IsInRole("Receptionist"))
            {
                <div class="col-12 col-md-3">
                    <label class="form-label small fw-semibold text-secondary">Doctor</label>
                    <select name="doctorId" class="form-select" asp-items="@ViewBag.Doctors">
                        <option value="">-- All Doctors --</option>
                    </select>
                </div>
            }

            <div class="col-12 col-md-2">
                <label class="form-label small fw-semibold text-secondary">Status</label>
                <select name="status" class="form-select">
                    <option value="">-- All Statuses --</option>
                    @foreach (var s in new[] { "Pending", "Approved", "Rejected", "Rescheduled", "Completed", "Cancelled", "No Show" })
                    {
                        <option value="@s" selected="@(ViewBag.Status == s)">@s</option>
                    }
                </select>
            </div>

            <div class="col-12 col-md-2">
                <label class="form-label small fw-semibold text-secondary">Type</label>
                <select name="type" class="form-select">
                    <option value="">-- All Types --</option>
                    @foreach (var t in new[] { "Video", "Voice" })
                    {
                        <option value="@t" selected="@(ViewBag.Type == t)">@t</option>
                    }
                </select>
            </div>

            <div class="col-12 col-md-2 d-flex align-items-end">
                <div class="form-check form-check-inline pb-2">
                    <input class="form-check-input" type="checkbox" name="isPriority" id="filterPriority" value="true" checked="@(ViewBag.IsPriority == true)" />
                    <label class="form-check-label small fw-semibold text-danger" for="filterPriority">Priority Only</label>
                </div>
            </div>

            <div class="col-12 col-md-3">
                <label class="form-label small fw-semibold text-secondary">Start Date</label>
                <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate" />
            </div>

            <div class="col-12 col-md-3">
                <label class="form-label small fw-semibold text-secondary">End Date</label>
                <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate" />
            </div>

            <div class="col-12 col-md-6 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary fw-medium px-4 py-2"><i class="bi bi-funnel me-1.5"></i>Apply Filters</button>
                <a href="@Url.Action("Index")" class="btn btn-light fw-medium px-3 py-2"><i class="bi bi-arrow-counterclockwise me-1.5"></i>Reset</a>
            </div>
        </form>
    </div>
</div>

<!-- Shortcuts Bar -->
<div class="d-flex flex-wrap gap-2 mb-3">
    <a href="@Url.Action("Index", new { status = "Pending" })" class="btn btn-sm btn-outline-warning rounded-pill">Pending Reviews</a>
    <a href="@Url.Action("Index", new { startDate = DateTime.Today.ToString("yyyy-MM-dd"), endDate = DateTime.Today.ToString("yyyy-MM-dd") })" class="btn btn-sm btn-outline-primary rounded-pill">Today's Schedule</a>
    <a href="@Url.Action("Index", new { isPriority = true })" class="btn btn-sm btn-outline-danger rounded-pill">Priority Alerts</a>
</div>

<!-- Registry Table Card -->
<div class="table-card">
    <div class="table-card-header">
        <h5 class="table-card-title mb-0">Scheduled Consultations</h5>
    </div>

    <div class="table-responsive">
        <table class="table custom-table">
            <thead>
                <tr>
                    <th>Date & Time</th>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Channel</th>
                    <th>Fee (INR)</th>
                    <th class="text-center">Urgency</th>
                    <th class="text-center">Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var appt in Model)
                    {
                        var statusBadgeClass = appt.Status.ToUpper() switch
                        {
                            "PENDING" => "bg-warning text-dark",
                            "APPROVED" => "bg-success text-white",
                            "REJECTED" => "bg-danger text-white",
                            "RESCHEDULED" => "bg-info text-white",
                            "COMPLETED" => "bg-secondary text-white",
                            "CANCELLED" => "bg-dark text-white",
                            "NO SHOW" => "bg-danger text-white",
                            _ => "bg-light text-dark"
                        };

                        var channelIcon = appt.AppointmentType.ToUpper() switch
                        {
                            "CLINIC" => "bi-hospital text-primary",
                            "VIDEO" => "bi-camera-video text-success",
                            "VOICE" => "bi-telephone text-info",
                            _ => "bi-chat"
                        };

                        <tr>
                            <td>
                                <div class="fw-semibold text-dark">@appt.AppointmentDate.ToString("dd-MMM-yyyy")</div>
                                <div class="text-muted small">@DateTime.Today.Add(appt.StartTime).ToString("hh:mm tt")</div>
                            </td>
                            <td>
                                <div class="fw-semibold text-dark">@appt.PatientName</div>
                                <div class="text-muted small">ID: PAT-@appt.PatientID</div>
                            </td>
                            <td>
                                <div class="fw-semibold text-dark">@appt.DoctorName</div>
                                <div class="text-muted text-truncate" style="max-width: 150px;">Branch: @(appt.BranchName ?? "Global")</div>
                            </td>
                            <td>
                                <i class="bi @channelIcon me-1.5"></i>@appt.AppointmentType
                            </td>
                            <td class="fw-semibold text-dark">
                                ₹@appt.ConsultationFee.ToString("N2")
                            </td>
                            <td class="text-center">
                                @if (appt.PriorityConsultation)
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-2.5">Priority</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-secondary rounded-pill px-2.5">Normal</span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge @statusBadgeClass rounded-pill px-2.5">@appt.Status</span>
                            </td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-1.5">
                                    <a href="@Url.Action("Details", new { id = appt.AppointmentID })" class="btn btn-outline-primary btn-sm px-2.5">
                                        <i class="bi bi-eye me-1"></i>View
                                    </a>
                                    @if (User.IsInRole("Doctor") && appt.Status.Equals("Approved", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <a href="@Url.Action("Workspace", "Consultation", new { id = appt.AppointmentID })" class="btn btn-success btn-sm px-2.5">
                                            <i class="bi bi-stethoscope me-1"></i>Consult
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center py-5">
                            <div class="text-muted mb-2"><i class="bi bi-calendar-x" style="font-size: 3rem;"></i></div>
                            <h6 class="text-dark">No appointments found matching your search.</h6>
                            <p class="text-muted small">Try modifying your filter settings or create a new booking.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination Footer -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="card-footer border-0 bg-transparent py-3">
            <nav aria-label="Appointments pagination">
                <ul class="pagination pagination-sm justify-content-center mb-0 gap-1">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link rounded-2" href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1, doctorId = ViewBag.DoctorId, patientId = ViewBag.PatientId, status = ViewBag.Status, type = ViewBag.Type, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, isPriority = ViewBag.IsPriority, searchTerm = ViewBag.SearchTerm })">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int p = 1; p <= ViewBag.TotalPages; p++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == p ? "active" : "")">
                            <a class="page-link rounded-2" href="@Url.Action("Index", new { page = p, doctorId = ViewBag.DoctorId, patientId = ViewBag.PatientId, status = ViewBag.Status, type = ViewBag.Type, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, isPriority = ViewBag.IsPriority, searchTerm = ViewBag.SearchTerm })">@p</a>
                        </li>
                    }
                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link rounded-2" href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1, doctorId = ViewBag.DoctorId, patientId = ViewBag.PatientId, status = ViewBag.Status, type = ViewBag.Type, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate, isPriority = ViewBag.IsPriority, searchTerm = ViewBag.SearchTerm })">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
