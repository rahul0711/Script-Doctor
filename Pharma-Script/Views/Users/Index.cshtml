@model IEnumerable<Pharma_Script.Models.User>
@using Pharma_Script.Helpers
@{
    Layout = "_Layout";
    ViewData["Title"] = "Users";
}

<div class="page-title-box">
    <div>
        <h4 class="page-title">Users</h4>
        <p class="text-muted small mb-0 font-medium">Manage hospital personnel accounts and system operators.</p>
    </div>
    <div>
        <button class="btn btn-primary fw-medium px-3.5 py-2" id="btnCreateUser">
            <i class="bi bi-plus-lg me-1.5"></i>Add User
        </button>
    </div>
</div>

<div class="table-card">
    <div class="table-card-header flex-column flex-md-row gap-3">
        <h5 class="table-card-title mb-0">System accounts</h5>
        
        <!-- Search -->
        <form method="get" action="@Url.Action("Index")" class="d-flex gap-2">
            <input type="text" name="searchTerm" class="form-control form-control-sm" placeholder="Search user..." value="@ViewBag.SearchTerm" style="width: 250px;" />
            <button type="submit" class="btn btn-primary btn-sm px-2.5"><i class="bi bi-search"></i></button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
            {
                <a href="@Url.Action("Index")" class="btn btn-light btn-sm px-2.5"><i class="bi bi-x-lg"></i></a>
            }
        </form>
    </div>

    <div class="table-responsive">
        <table class="table custom-table">
            <thead>
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>User</th>
                    @if (User.IsPlatformOwner())
                    {
                        <th>Organization</th>
                    }
                    <th>Role</th>
                    <th>Contact Info</th>
                    <th class="text-center" style="width: 100px;">Status</th>
                    <th class="text-end" style="width: 200px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.UserID</td>
                            <td class="fw-semibold text-dark">@item.FirstName @item.LastName</td>
                            @if (User.IsPlatformOwner())
                            {
                                <td class="small fw-medium text-secondary">@(string.IsNullOrEmpty(item.OrganizationName) ? "Platform Owner" : item.OrganizationName)</td>
                            }
                            <td><span class="badge bg-light text-secondary border rounded px-2.5 py-1 small">@item.RoleName</span></td>
                            <td>
                                <div class="small"><i class="bi bi-envelope text-muted me-1.5"></i>@item.Email</div>
                                @if (!string.IsNullOrEmpty(item.Phone))
                                {
                                    <div class="small"><i class="bi bi-telephone text-muted me-1.5"></i>@item.Phone</div>
                                }
                            </td>
                            <td class="text-center">
                                <div class="form-check form-switch d-inline-block">
                                    <input class="form-check-input status-toggle" type="checkbox" data-id="@item.UserID" @(item.IsActive ? "checked" : "") style="cursor: pointer;" />
                                </div>
                            </td>
                            <td class="text-end">
                                <button class="btn-action btnChangePassword" data-id="@item.UserID" title="Change Password">
                                    <i class="bi bi-key"></i>
                                </button>
                                <button class="btn-action btnView" data-id="@item.UserID" title="View Profile">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <button class="btn-action btn-action-edit btnEdit" data-id="@item.UserID" title="Edit">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                                <button class="btn-action btn-action-delete btnDelete" data-id="@item.UserID" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="@(User.IsPlatformOwner() ? 7 : 6)" class="text-center py-5 text-muted small">No users found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="pagination-container">
            <div class="pagination-info">
                Showing page @ViewBag.CurrentPage of @ViewBag.TotalPages (@ViewBag.TotalItems records)
            </div>
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { searchTerm = ViewBag.SearchTerm, page = ViewBag.CurrentPage - 1, pageSize = ViewBag.PageSize })">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { searchTerm = ViewBag.SearchTerm, page = i, pageSize = ViewBag.PageSize })">@i</a>
                        </li>
                    }
                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { searchTerm = ViewBag.SearchTerm, page = ViewBag.CurrentPage + 1, pageSize = ViewBag.PageSize })">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Modal -->
<div class="modal fade" id="userModal" tabindex="-1" aria-labelledby="userModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="userModalLabel">User Modal</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="userModalBody">
                <!-- Content loaded dynamically -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var modal = new bootstrap.Modal(document.getElementById('userModal'));

            // Load Create
            $('#btnCreateUser').on('click', function () {
                $('#userModalLabel').text('Create System Account');
                $('#userModalBody').html('<div class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary" role="status"></div><p class="mt-2 text-muted small">Loading form...</p></div>');
                modal.show();

                $.get('@Url.Action("Create")', function (html) {
                    $('#userModalBody').html(html);
                    $.validator.unobtrusive.parse('#userModalBody');
                });
            });

            // Load Edit
            $(document).on('click', '.btnEdit', function () {
                var id = $(this).data('id');
                $('#userModalLabel').text('Edit User Settings');
                $('#userModalBody').html('<div class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary" role="status"></div><p class="mt-2 text-muted small">Loading settings...</p></div>');
                modal.show();

                $.get('@Url.Action("Edit")/' + id, function (html) {
                    $('#userModalBody').html(html);
                    $.validator.unobtrusive.parse('#userModalBody');
                });
            });

            // Load Details
            $(document).on('click', '.btnView', function () {
                var id = $(this).data('id');
                $('#userModalLabel').text('User Account Profile');
                $('#userModalBody').html('<div class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary" role="status"></div><p class="mt-2 text-muted small">Loading details...</p></div>');
                modal.show();

                $.get('@Url.Action("Details")/' + id, function (html) {
                    $('#userModalBody').html(html);
                });
            });

            // Load Change Password
            $(document).on('click', '.btnChangePassword', function () {
                var id = $(this).data('id');
                $('#userModalLabel').text('Reset Password');
                $('#userModalBody').html('<div class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary" role="status"></div><p class="mt-2 text-muted small">Loading reset form...</p></div>');
                modal.show();

                $.get('@Url.Action("ChangePassword")/' + id, function (html) {
                    $('#userModalBody').html(html);
                    $.validator.unobtrusive.parse('#userModalBody');
                });
            });

            // Form Submit via AJAX
            $(document).on('submit', '#userModalBody form', function (e) {
                e.preventDefault();
                var form = $(this);
                if (!form.valid()) return false;

                var btnSubmit = form.find('button[type="submit"]');
                var originalHtml = btnSubmit.html();
                btnSubmit.html('<span class="spinner-border spinner-border-sm me-1.5" role="status"></span>Saving...').prop('disabled', true);

                $.ajax({
                    url: form.attr('action'),
                    type: form.attr('method'),
                    data: form.serialize(),
                    success: function (res) {
                        if (res.success) {
                            modal.hide();
                            Swal.fire({
                                icon: 'success',
                                title: 'Success',
                                text: res.message,
                                timer: 1500,
                                showConfirmButton: false
                            }).then(function () {
                                location.reload();
                            });
                        } else {
                            btnSubmit.html(originalHtml).prop('disabled', false);
                            var errorMsg = res.message;
                            if (res.errors && res.errors.length > 0) {
                                errorMsg += '\n' + res.errors.join('\n');
                            }
                            Swal.fire({
                                icon: 'error',
                                title: 'Validation Error',
                                text: errorMsg
                            });
                        }
                    },
                    error: function () {
                        btnSubmit.html(originalHtml).prop('disabled', false);
                        Swal.fire({
                            icon: 'error',
                            title: 'System Error',
                            text: 'An unexpected system error occurred.'
                        });
                    }
                });
            });

            // Toggle active status
            $('.status-toggle').on('change', function () {
                var toggle = $(this);
                var id = toggle.data('id');
                var isActive = toggle.is(':checked');

                $.ajax({
                    url: '@Url.Action("ToggleStatus")',
                    type: 'POST',
                    data: {
                        id: id,
                        isActive: isActive,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (res) {
                        if (res.success) {
                            const Toast = Swal.mixin({
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 2000,
                                timerProgressBar: true
                            });
                            Toast.fire({
                                icon: 'success',
                                title: res.message
                            });
                        } else {
                            toggle.prop('checked', !isActive);
                            Swal.fire({
                                icon: 'error',
                                title: 'Action Failed',
                                text: res.message
                            });
                        }
                    },
                    error: function () {
                        toggle.prop('checked', !isActive);
                        Swal.fire({
                            icon: 'error',
                            title: 'Connection Error',
                            text: 'Failed to update user status.'
                        });
                    }
                });
            });

            // Delete action
            $(document).on('click', '.btnDelete', function () {
                var id = $(this).data('id');

                Swal.fire({
                    title: 'Delete User Account?',
                    text: "This user will lose access to the system. This cannot be undone.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#64748b',
                    confirmButtonText: 'Yes, Delete',
                    cancelButtonText: 'Cancel'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("Delete")/' + id,
                            type: 'POST',
                            data: {
                                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                            },
                            success: function (res) {
                                if (res.success) {
                                    Swal.fire({
                                        icon: 'success',
                                        title: 'Deleted',
                                        text: res.message,
                                        timer: 1500,
                                        showConfirmButton: false
                                    }).then(function () {
                                        location.reload();
                                    });
                                } else {
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Action Failed',
                                        text: res.message
                                    });
                                }
                            },
                            error: function () {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Connection Error',
                                    text: 'Failed to delete user.'
                                });
                            }
                        });
                    }
                });
            });
        });
    </script>
}
