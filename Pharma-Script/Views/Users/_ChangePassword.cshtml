@model Pharma_Script.ViewModels.User.ChangePasswordViewModel

<form asp-action="ChangePassword" asp-controller="Users" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="UserID" />

    <div class="row g-3">
        <div class="col-12">
            <div class="p-3 bg-light rounded-3 text-secondary small border mb-2 d-flex gap-2 align-items-start">
                <i class="bi bi-info-circle text-primary fs-5 mt-0.5"></i>
                <div>
                    Enter a new secure password for the user account below. The user will be required to authenticate with this password on their next sign-in.
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6">
            <label asp-for="NewPassword" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="NewPassword" class="form-control" type="password" placeholder="••••••••" required />
            <span asp-validation-for="NewPassword" class="text-danger small" style="font-size: 0.75rem;"></span>
        </div>

        <div class="col-12 col-md-6">
            <label asp-for="ConfirmNewPassword" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="ConfirmNewPassword" class="form-control" type="password" placeholder="••••••••" required />
            <span asp-validation-for="ConfirmNewPassword" class="text-danger small" style="font-size: 0.75rem;"></span>
        </div>
    </div>

    <div class="modal-footer px-0 pb-0 mt-4 border-0">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Reset Password</button>
    </div>
</form>
