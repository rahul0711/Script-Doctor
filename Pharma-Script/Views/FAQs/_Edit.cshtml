@model Pharma_Script.ViewModels.CMS.FAQViewModel

<form asp-action="Edit" asp-controller="FAQs" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="FAQID" />
    <div class="row g-3">
        <div class="col-12">
            <label asp-for="Question" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="Question" class="form-control" />
            <span asp-validation-for="Question" class="text-danger small"></span>
        </div>
        <div class="col-12">
            <label asp-for="Answer" class="form-label small fw-semibold text-secondary"></label>
            <textarea asp-for="Answer" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Answer" class="text-danger small"></span>
        </div>
        <div class="col-12 col-md-4">
            <label asp-for="DisplayOrder" class="form-label small fw-semibold text-secondary"></label>
            <input asp-for="DisplayOrder" type="number" min="1" class="form-control" />
        </div>
        <div class="col-12 col-md-8 d-flex align-items-end">
            <div class="form-check mb-2">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label small fw-semibold text-secondary">Active</label>
            </div>
        </div>
    </div>
    <div class="modal-footer px-0 pb-0 mt-4 border-0">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Update FAQ</button>
    </div>
</form>
